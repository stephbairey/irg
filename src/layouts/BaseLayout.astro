---
import "../styles/global.css";
import JsonLd from "../components/JsonLd.astro";

interface Props {
  title: string;
  description?: string;
  structuredData?: object | object[];
}

const { title, description = "Using creative and humorous protests for political education.", structuredData } = Astro.props;
const year = new Date().getFullYear();
const path = Astro.url.pathname;

const SITE_URL = Astro.site?.toString().replace(/\/$/, "") ?? "https://raginggrannies.org";

const baselineSchemas: Record<string, unknown>[] = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}#org`,
    name: "International Raging Grannies",
    url: SITE_URL,
    logo: `${SITE_URL}/logo-cropped.svg`,
    description: "Using creative and humorous protests for political education.",
    foundingDate: "1987",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}#website`,
    url: SITE_URL,
    name: "Raging Grannies",
    description: "Using creative and humorous protests for political education.",
    publisher: { "@id": `${SITE_URL}#org` },
  },
];

const pageSchemas = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];

const allSchemas = [...baselineSchemas, ...(pageSchemas as Record<string, unknown>[])];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Raging Grannies</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito+Sans:ital,wght@0,300;0,400;0,600;0,700;0,800;0,900;1,400;1,700&family=Rum+Raisin&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/logo-cropped.svg" />
    <script is:inline>
      // Apply saved text-zoom level before first paint to avoid flash. The
      // click handler at the bottom of body keeps the visible state in sync.
      (function () {
        try {
          var v = localStorage.getItem("rg-text-zoom");
          if (v === "bigger" || v === "quite-big") {
            document.documentElement.setAttribute("data-text-zoom", v);
          }
        } catch (e) {}
      })();
    </script>
    <JsonLd data={allSchemas} />
  </head>
  <body>
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b-[1.5px] border-rule bg-paper" style="backdrop-filter:saturate(1.1)">
      <div class="flex justify-between items-center max-w-[1400px] mx-auto px-8 py-4">
        <a href="/" class="flex items-center gap-3 no-underline text-ink" aria-label="Raging Grannies International, Home">
          <img src="/logo-cropped.svg" alt="" class="w-[38px] h-[38px] object-contain" />
          <div>
            <span class="font-display text-2xl leading-none text-ink block">Raging Grannies</span>
            <span class="font-body font-[800] text-[11px] tracking-[.14em] uppercase text-muted block mt-1">International Network · Est. 1987</span>
          </div>
        </a>

        {/* Desktop nav: visible at md+ */}
        <nav aria-label="Main" class="hidden md:flex items-center gap-7">
          <a href="/about/" class:list={["font-bold text-[15px] no-underline hover:text-red transition-colors", path.startsWith("/about") ? "text-red" : "text-text"]}>About</a>
          <a href="/in-the-news/" class:list={["font-bold text-[15px] no-underline hover:text-red transition-colors", path.startsWith("/in-the-news") || path.startsWith("/photos") ? "text-red" : "text-text"]}>News</a>
          <a href="/ask/" class:list={["font-bold text-[15px] no-underline hover:text-red transition-colors", path.startsWith("/ask") ? "text-red" : "text-text"]}>Ask a Question</a>
          <a href="/find-a-gaggle/" class:list={["font-bold text-[15px] no-underline hover:text-red transition-colors", path.startsWith("/find-a-gaggle") ? "text-red" : "text-text"]}>Find a Gaggle</a>
          <a href="/start-a-gaggle/" class:list={["font-bold text-[15px] no-underline hover:text-red transition-colors", path.startsWith("/start-a-gaggle") ? "text-red" : "text-text"]}>Start a Gaggle</a>
          <a href="/songs/" class="px-[18px] py-[10px] rounded-full text-sm font-bold no-underline transition-colors text-white bg-red hover:bg-ink-soft">Songs</a>
        </nav>

        {/* Mobile hamburger: visible below md */}
        <button
          id="nav-toggle"
          class="md:hidden inline-flex items-center justify-center w-11 h-11 rounded-md text-ink hover:bg-paper-2 transition-colors"
          type="button"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg class="nav-toggle-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="4" y1="7" x2="20" y2="7" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="17" x2="20" y2="17" />
          </svg>
          <svg class="nav-toggle-close hidden" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="6" y1="6" x2="18" y2="18" />
            <line x1="18" y1="6" x2="6" y2="18" />
          </svg>
        </button>
      </div>

      {/* Mobile menu drawer: slides down from header on toggle */}
      <div
        id="mobile-menu"
        class="md:hidden hidden bg-paper border-t border-rule"
        aria-hidden="true"
      >
        <nav aria-label="Mobile" class="max-w-[1400px] mx-auto px-8 py-4 grid gap-1">
          <a href="/about/" class:list={["mobile-link", path.startsWith("/about") && "is-active"]}>About</a>
          <a href="/in-the-news/" class:list={["mobile-link", (path.startsWith("/in-the-news") || path.startsWith("/photos")) && "is-active"]}>News</a>
          <a href="/ask/" class:list={["mobile-link", path.startsWith("/ask") && "is-active"]}>Ask a Question</a>
          <a href="/find-a-gaggle/" class:list={["mobile-link", path.startsWith("/find-a-gaggle") && "is-active"]}>Find a Gaggle</a>
          <a href="/start-a-gaggle/" class:list={["mobile-link", path.startsWith("/start-a-gaggle") && "is-active"]}>Start a Gaggle</a>
          <a href="/songs/" class:list={["mobile-link mobile-link-pill", path.startsWith("/songs") && "is-active"]}>Songs</a>
        </nav>
      </div>
    </header>

    <script>
      // Mobile nav toggle. Vanilla JS, no deps. Closes on link tap, on Escape,
      // and when the viewport grows past the md breakpoint.
      (() => {
        const btn = document.getElementById("nav-toggle");
        const menu = document.getElementById("mobile-menu");
        if (!btn || !menu) return;

        const iconOpen = btn.querySelector(".nav-toggle-open");
        const iconClose = btn.querySelector(".nav-toggle-close");

        function setOpen(open) {
          btn.setAttribute("aria-expanded", open ? "true" : "false");
          btn.setAttribute("aria-label", open ? "Close menu" : "Open menu");
          menu.classList.toggle("hidden", !open);
          menu.setAttribute("aria-hidden", open ? "false" : "true");
          iconOpen?.classList.toggle("hidden", open);
          iconClose?.classList.toggle("hidden", !open);
          document.body.style.overflow = open ? "hidden" : "";
        }

        btn.addEventListener("click", () => {
          const open = btn.getAttribute("aria-expanded") === "true";
          setOpen(!open);
        });

        // Tap a link → close (then the browser navigates).
        menu.addEventListener("click", (e) => {
          const target = e.target;
          if (target instanceof HTMLAnchorElement) setOpen(false);
        });

        // Escape closes.
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && btn.getAttribute("aria-expanded") === "true") {
            setOpen(false);
            btn.focus();
          }
        });

        // If user resizes/rotates above md, force-close so state stays sane.
        const mq = window.matchMedia("(min-width: 768px)");
        mq.addEventListener("change", (e) => {
          if (e.matches) setOpen(false);
        });
      })();

    </script>

    <style>
      /* Mobile menu links — match Bulletin language: cream bg, deep purple
         text, brand-red accent on hover and active route. */
      .mobile-link {
        display: block;
        padding: 14px 12px;
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 17px;
        color: var(--color-text);
        text-decoration: none;
        border-bottom: 1px solid var(--color-rule);
        transition: color 0.15s ease, padding 0.15s ease;
      }
      .mobile-link:last-child { border-bottom: 0; }
      .mobile-link:hover, .mobile-link:focus-visible {
        color: var(--color-red);
        padding-left: 18px;
        outline: none;
      }
      .mobile-link.is-active { color: var(--color-red); }
      /* Songs link styled as a pill in the mobile menu, matching desktop. */
      .mobile-link-pill {
        align-self: start;
        margin-top: 8px;
        padding: 12px 18px;
        background: var(--color-red);
        color: #fff;
        border: 0;
        border-radius: 999px;
        text-align: center;
      }
      .mobile-link-pill:hover, .mobile-link-pill:focus-visible {
        background: var(--color-ink-soft);
        color: #fff;
        padding-left: 18px;
      }

      /* Footer link sections: collapsible accordion on mobile, always-open
         columns on desktop. The <details> element handles toggling for
         free; on desktop we override the closed state to keep contents
         visible and disable the summary's interactive UI. */
      .footer-section {
        border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      }
      .footer-section > summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 14px 0;
        font-family: var(--font-body);
        font-weight: 800;
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--color-ink-lilac);
      }
      .footer-section > summary::-webkit-details-marker { display: none; }
      .footer-section > summary::marker { display: none; }
      .footer-section > summary::after {
        content: "▾";
        font-size: 14px;
        transition: transform 0.15s ease;
      }
      .footer-section[open] > summary::after { transform: rotate(180deg); }
      .footer-section > ul { padding: 0 0 16px; }

      @media (min-width: 768px) {
        /* Desktop: render exactly like before — heading + always-visible list,
           no toggle UI. The summary becomes a plain heading. */
        .footer-section { border-bottom: 0; }
        .footer-section > summary {
          cursor: default;
          pointer-events: none;
          padding: 0;
          margin-bottom: 16px;
        }
        .footer-section > summary::after { content: ""; display: none; }
        .footer-section:not([open]) > ul,
        .footer-section[open] > ul { display: block; padding: 0; }
      }
    </style>

    <slot />

    <!-- Footer -->
    <footer class="mt-16 md:mt-24 bg-ink text-on-dark pt-12 md:pt-14 pb-8">
      <div class="grid grid-cols-1 md:grid-cols-[1.7fr_1fr_1fr_1.2fr_1fr] gap-0 md:gap-12 max-w-[1200px] mx-auto px-5 md:px-8">
        <!-- Brand column -->
        <div class="mb-2 md:mb-0">
          <div class="flex items-center gap-3 mb-4">
            <img src="/logo-full.svg" alt="" class="h-[54px] brightness-0 invert opacity-90" />
            <span class="font-display text-2xl text-on-dark">Raging Grannies</span>
          </div>
          <p class="text-[15px] text-ink-lilac leading-relaxed max-w-[340px]">
            A network of women over 50, singing satire into the face of injustice as long as it's needed.
          </p>
        </div>
        <!-- Songs -->
        <details class="footer-section">
          <summary>The Songs</summary>
          <ul class="space-y-2 text-[15px]">
            <li><a href="/songs/" class="text-on-dark no-underline hover:text-red">Browse</a></li>
            <li><a href="/songs/by-issue/" class="text-on-dark no-underline hover:text-red">By issue</a></li>
            <li><a href="/songs/by-tune/" class="text-on-dark no-underline hover:text-red">By tune</a></li>
            <li><a href="/submit/" class="text-on-dark no-underline hover:text-red">Add a Song</a></li>
          </ul>
        </details>
        <!-- About -->
        <details class="footer-section">
          <summary>About Us</summary>
          <ul class="space-y-2 text-[15px]">
            <li><a href="/about/" class="text-on-dark no-underline hover:text-red">About</a></li>
            <li><a href="/herstory/" class="text-on-dark no-underline hover:text-red">Herstory</a></li>
            <li><a href="/philosophy/" class="text-on-dark no-underline hover:text-red">Philosophy</a></li>
            <li><a href="/faq/" class="text-on-dark no-underline hover:text-red">FAQ</a></li>
          </ul>
        </details>
        <!-- Media -->
        <details class="footer-section">
          <summary>Media</summary>
          <ul class="space-y-2 text-[15px]">
            <li><a href="/photos/" class="text-on-dark no-underline hover:text-red">Photos</a></li>
            <li><a href="/videos/" class="text-on-dark no-underline hover:text-red">Videos</a></li>
            <li><a href="/fact-sheet/" class="text-on-dark no-underline hover:text-red">Fact sheet</a></li>
            <li><a href="/in-the-news/" class="text-on-dark no-underline hover:text-red">News</a></li>
          </ul>
        </details>
        <!-- Connect -->
        <details class="footer-section">
          <summary>Connect</summary>
          <ul class="space-y-2 text-[15px]">
            <li><a href="/contact/" class="text-on-dark no-underline hover:text-red">Contact</a></li>
            <li><a href="/ask/" class="text-on-dark no-underline hover:text-red">Ask a question</a></li>
          </ul>
        </details>
      </div>
      <!-- Bottom bar -->
      <div class="max-w-[1200px] mx-auto mt-10 pt-6 px-5 md:px-8 border-t border-white/15 flex flex-col md:flex-row gap-3 md:gap-6 md:justify-between items-center text-[13px] text-ink-lilac text-center md:text-left">
        <span>&copy; <span class="copyright-year">{year}</span> International Raging Grannies</span>
        <span class="flex flex-wrap justify-center gap-x-4 gap-y-1">
          <a href="/privacy/" class="text-ink-lilac no-underline hover:text-on-dark">Privacy</a>
          <span aria-hidden="true">·</span>
          <span>Made with spirit, by volunteers.</span>
        </span>
      </div>
    </footer>

    <div class="text-zoom" role="group" aria-label="Text size">
      <button type="button" class="text-zoom-btn" data-zoom="default" aria-pressed="true" aria-label="Default text size">A</button>
      <button type="button" class="text-zoom-btn" data-zoom="bigger" aria-pressed="false" aria-label="Bigger text">A<span aria-hidden="true">+</span></button>
      <button type="button" class="text-zoom-btn" data-zoom="quite-big" aria-pressed="false" aria-label="Quite big text">A<span aria-hidden="true">++</span></button>
    </div>

    <script is:inline>
      // Text-size control: cycles html[data-text-zoom] and persists in
      // localStorage. Pre-paint apply lives in <head>; this handler keeps
      // aria-pressed in sync after load.
      (function () {
        var root = document.documentElement;
        var btns = document.querySelectorAll(".text-zoom-btn");
        if (!btns.length) return;
        function apply(level) {
          if (level === "bigger" || level === "quite-big") {
            root.setAttribute("data-text-zoom", level);
          } else {
            root.removeAttribute("data-text-zoom");
            level = "default";
          }
          btns.forEach(function (b) {
            b.setAttribute("aria-pressed", String(b.getAttribute("data-zoom") === level));
          });
        }
        var saved = null;
        try { saved = localStorage.getItem("rg-text-zoom"); } catch (e) {}
        apply(saved);
        btns.forEach(function (b) {
          b.addEventListener("click", function () {
            var level = b.getAttribute("data-zoom");
            apply(level);
            try {
              if (level === "default") {
                localStorage.removeItem("rg-text-zoom");
              } else {
                localStorage.setItem("rg-text-zoom", level);
              }
            } catch (e) {}
          });
        });
      })();
    </script>

    <script is:inline>
      // Keep the copyright year correct even if the static build is months old.
      for (const el of document.querySelectorAll(".copyright-year")) {
        el.textContent = String(new Date().getFullYear());
      }
      // Same idea for the homepage "Years singing" stat: roll the count over
      // automatically each new year without needing a rebuild.
      for (const el of document.querySelectorAll(".years-singing")) {
        el.textContent = String(new Date().getFullYear() - 1987);
      }
      // Footer link accordions: collapsed on mobile, fully expanded on desktop.
      // CSS alone can't reliably override the browser's ::details-content
      // rendering for closed <details>, so we drive the [open] attribute from
      // a media query. Has to run AFTER the footer parses, hence is:inline at
      // end of body (the bundled <script> after </header> ran too early and
      // querySelectorAll returned 0 elements).
      (function () {
        const sections = document.querySelectorAll(".footer-section");
        if (!sections.length) return;
        const mq = window.matchMedia("(min-width: 768px)");
        const apply = function () {
          for (const s of sections) s.open = mq.matches;
        };
        apply();
        mq.addEventListener("change", apply);
      })();
    </script>
  </body>
</html>
