---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchAllSongs } from "../../lib/songs";

const allSongs = await fetchAllSongs();

const allIssues = [
  ...new Set(allSongs.flatMap((s) => s.issues.nodes.map((i) => i.name))),
].sort();

const allGaggles = [
  ...new Set(allSongs.flatMap((s) => s.gaggles.nodes.map((g) => g.name))),
].sort();

const allTunes = [
  ...new Set(allSongs.flatMap((s) => s.tunes.nodes.map((t) => t.name))),
].sort();

const songsJson = JSON.stringify(
  allSongs.map((s) => ({
    t: s.title,
    s: s.slug,
    g: s.gaggles.nodes[0]?.name ?? "",
    w: s.songwriters.nodes[0]?.name ?? "",
    n: s.tunes.nodes[0]?.name ?? "",
    i: s.issues.nodes.map((i) => i.name),
    y: s.date?.slice(0, 4) ?? "",
  })),
);
---

<BaseLayout title="The Song Library">
  <!-- Header -->
  <section class="pt-10 md:pt-14 pb-6 max-w-[1200px] mx-auto px-5 md:px-8">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 md:gap-12 items-end">
      <div>
        <div class="kicker text-red mb-3">The Songbook · 1987-2026</div>
        <h1 class="font-display text-ink leading-[.98] mb-4" style="font-size:clamp(40px,9vw,96px)">The Song Library</h1>
        <p class="text-[17px] md:text-[19px] text-text-soft max-w-[640px] leading-normal">
          Every song catalogued by gaggles across four continents: searchable, filterable, printable, and <em class="text-ink">yours to sing</em>.
        </p>
      </div>
      <div class="p-[16px_20px] md:p-[22px_28px] bg-ink text-on-dark rounded-[10px] text-right self-start md:self-auto inline-block md:block w-fit md:w-auto" style="transform:rotate(1.5deg);box-shadow:var(--shadow-lift)">
        <div class="font-display text-mustard text-[40px] md:text-[56px] leading-none">{allSongs.length.toLocaleString()}</div>
        <div class="font-[800] text-xs tracking-[.1em] uppercase text-ink-lilac mt-2">Songs & counting</div>
      </div>
    </div>
  </section>

  <!-- Search bar (sticky) -->
  <section class="sticky top-[73px] z-40 bg-paper border-b border-rule py-4 md:py-5">
    <div class="max-w-[1200px] mx-auto px-5 md:px-8">
      <div class="flex items-center gap-3.5 px-5 py-3.5 bg-card border-2 border-muted rounded-full" style="box-shadow:var(--shadow-card)">
        <svg viewBox="0 0 24 24" class="w-[18px] h-[18px] text-ink flex-none" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="20" y1="20" x2="16.5" y2="16.5"/></svg>
        <input
          type="text"
          id="lib-search"
          placeholder="Search by title, tune, or a line in the lyrics..."
          class="flex-1 border-0 bg-transparent text-lg text-ink outline-none placeholder:text-muted"
        />
        <button id="lib-search-clear" class="hidden font-[800] text-red text-[13px] px-2.5 py-1 bg-transparent border-0 cursor-pointer">Clear</button>
      </div>
      <!-- Active filters + result count -->
      <div id="lib-activebar" class="flex justify-between items-center mt-4 gap-4 flex-wrap">
        <div id="lib-result-count" class="text-sm text-text-soft flex items-center gap-2.5 flex-wrap"></div>
        <div class="flex items-center gap-2.5">
          <label class="font-[800] text-xs tracking-[.1em] uppercase text-muted">Sort</label>
          <div class="relative">
            <select id="lib-sort" class="appearance-none px-3.5 py-2.5 pr-9 text-sm font-bold bg-card text-ink border-[1.5px] border-muted rounded-lg cursor-pointer min-h-[40px]">
              <option value="a-z">A → Z</option>
              <option value="z-a">Z → A</option>
              <option value="newest">Newest</option>
            </select>
            <svg viewBox="0 0 24 24" class="absolute right-3 top-1/2 -translate-y-1/2 w-[14px] h-[14px] text-ink pointer-events-none" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Body: filters + results -->
  <section class="max-w-[1200px] mx-auto px-5 md:px-8 py-6 md:py-8 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-[280px_1fr] gap-6 md:gap-12 items-start">
      <!-- Left rail filters: collapsible accordion on mobile, sticky aside on desktop -->
      <details class="lib-filter-panel md:sticky md:top-[220px]">
        <summary class="lib-filter-summary md:hidden">
          <span>Filters</span>
          <span class="lib-filter-chev">▾</span>
        </summary>
        <aside id="lib-filters" class="grid gap-5 pt-4 md:pt-0">
          {[
            { id: "lib-issue", label: "Issue", placeholder: "All issues", options: allIssues },
            { id: "lib-gaggle", label: "Gaggle", placeholder: "All gaggles", options: allGaggles },
            { id: "lib-tune", label: "Tune", placeholder: "All tunes", options: allTunes },
          ].map(({ id, label, placeholder, options }) => (
            <div>
              <label for={id} class="kicker text-ink mb-2 block">{label}</label>
              <div class="relative">
                <select
                  id={id}
                  class="lib-tax-select appearance-none w-full pl-3.5 pr-10 py-2.5 text-sm font-bold bg-card text-ink border-[1.5px] border-muted rounded-lg cursor-pointer min-h-[40px] focus:outline-none focus:border-red"
                >
                  <option value="">{placeholder}</option>
                  {options.map((opt) => (
                    <option value={opt}>{opt}</option>
                  ))}
                </select>
                <svg viewBox="0 0 24 24" class="absolute right-3 top-1/2 -translate-y-1/2 w-[14px] h-[14px] text-ink pointer-events-none" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
              </div>
            </div>
          ))}

          <button id="lib-reset" class="px-4 py-2.5 bg-transparent border-[1.5px] border-rule rounded-lg font-[800] text-red cursor-pointer text-[13px] hover:border-red hover:bg-red/[.05] mt-1">
            Reset all filters
          </button>
        </aside>
      </details>

      <!-- Results -->
      <div>
        <div id="lib-results" class="grid gap-0"></div>
        <p id="lib-no-results" class="hidden text-center text-text-soft py-16 text-lg">No songs match your filters.</p>
        <!-- Pagination -->
        <div id="lib-pager" class="flex justify-between items-center mt-10 gap-4 flex-wrap">
          <span id="lib-pager-info" class="text-sm text-muted"></span>
          <div class="flex gap-2">
            <button id="lib-prev" class="btn-mini" disabled>← Previous</button>
            <button id="lib-next" class="btn-mini">Next →</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script define:vars={{ songsJson }}>
    const ALL = JSON.parse(songsJson);
    const PER_PAGE = 50;

    let filters = { q: "", issue: "", gaggle: "", tune: "", songwriter: "" };
    let sort = "a-z";
    let page = 1;

    const $ = (s) => document.querySelector(s);
    const $$ = (s) => document.querySelectorAll(s);

    const searchInput = $("#lib-search");
    const clearBtn = $("#lib-search-clear");
    const sortSelect = $("#lib-sort");
    const resultCount = $("#lib-result-count");
    const resultsDiv = $("#lib-results");
    const noResults = $("#lib-no-results");
    const pagerInfo = $("#lib-pager-info");
    const prevBtn = $("#lib-prev");
    const nextBtn = $("#lib-next");
    const resetBtn = $("#lib-reset");

    const taxSelects = {
      issue: $("#lib-issue"),
      gaggle: $("#lib-gaggle"),
      tune: $("#lib-tune"),
    };

    // Filter ALL songs by an arbitrary subset of filter keys. Pass `excluding`
    // to drop one filter from the constraint — used by the cascading
    // dropdowns to compute "what's still selectable".
    function filterSongs(excluding) {
      const q = filters.q.toLowerCase();
      return ALL.filter((s) => {
        if (q && !s.t.toLowerCase().includes(q) && !s.n.toLowerCase().includes(q)) return false;
        if (excluding !== "issue" && filters.issue && !s.i.includes(filters.issue)) return false;
        if (excluding !== "gaggle" && filters.gaggle && s.g !== filters.gaggle) return false;
        if (excluding !== "tune" && filters.tune && s.n !== filters.tune) return false;
        if (excluding !== "songwriter" && filters.songwriter && s.w !== filters.songwriter) return false;
        return true;
      });
    }

    function applyFilters() {
      return filterSongs(null);
    }

    function availableTerms(key) {
      const songs = filterSongs(key);
      const set = new Set();
      // NOTE: the inner `if` bodies need braces. Without them, dangling-else
      // attachment binds the next `else if` to the inner `if (s.g)` rather
      // than the outer `if (key === ...)`, silently eating the next branch.
      if (key === "issue") {
        for (const s of songs) for (const v of s.i) set.add(v);
      } else if (key === "gaggle") {
        for (const s of songs) if (s.g) set.add(s.g);
      } else if (key === "tune") {
        for (const s of songs) if (s.n) set.add(s.n);
      }
      return [...set].sort((a, b) => a.localeCompare(b));
    }

    function rebuildDropdown(key, placeholder) {
      const select = taxSelects[key];
      if (!select) return;
      const available = availableTerms(key);
      const current = filters[key];
      // Keep the active selection visible even if it now yields zero matches.
      const values = current && !available.includes(current) ? [current, ...available] : available;
      const frag = document.createDocumentFragment();
      const ph = document.createElement("option");
      ph.value = "";
      ph.textContent = placeholder;
      frag.appendChild(ph);
      for (const v of values) {
        const opt = document.createElement("option");
        opt.value = v;
        opt.textContent = v;
        frag.appendChild(opt);
      }
      select.replaceChildren(frag);
      select.value = current;
    }

    function syncDropdowns() {
      rebuildDropdown("issue", "All issues");
      rebuildDropdown("gaggle", "All gaggles");
      rebuildDropdown("tune", "All tunes");
    }

    function sortSongs(songs) {
      const s = [...songs];
      if (sort === "a-z") s.sort((a, b) => a.t.localeCompare(b.t));
      else if (sort === "z-a") s.sort((a, b) => b.t.localeCompare(a.t));
      else if (sort === "newest") s.sort((a, b) => (b.y || "0").localeCompare(a.y || "0"));
      return s;
    }

    function escAttr(s) {
      return String(s).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    function renderRow(s) {
      const chips = s.i
        .map((i) => `<button type="button" class="chip lib-result-chip" data-issue="${escAttr(i)}" style="font-size:12px;padding:3px 9px">${escAttr(i)}</button>`)
        .join("");
      return `<div class="grid grid-cols-[1fr_auto] gap-8 py-[22px] px-1 border-b border-rule text-text items-center transition-all hover:bg-paper-2 hover:pl-5 hover:pr-5 group">
        <div>
          <a href="/songs/${s.s}/" class="block font-display text-ink text-[30px] leading-none mb-2 no-underline hover:text-red transition-colors">${s.t}</a>
          <div class="text-sm text-text-soft mb-2.5">
            ${s.n ? `<em class="text-ink-soft italic">${s.n}</em>` : ""}
            ${s.n && s.g ? '<span class="text-ink-lilac mx-1.5">·</span>' : ""}
            ${s.g || ""}
            ${s.w ? '<span class="text-ink-lilac mx-1.5">·</span>' + s.w : ""}
          </div>
          <div class="flex gap-2 items-center flex-wrap">${chips}</div>
        </div>
        <div class="font-display text-muted text-[28px]">${s.y}</div>
      </div>`;
    }

    function render() {
      const filtered = sortSongs(applyFilters());
      const totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
      if (page > totalPages) page = totalPages;
      const start = (page - 1) * PER_PAGE;
      const pageItems = filtered.slice(start, start + PER_PAGE);

      resultsDiv.innerHTML = pageItems.map(renderRow).join("");
      noResults.classList.toggle("hidden", pageItems.length > 0);

      const countHtml = `<b class="font-display text-ink text-xl">${filtered.length}</b> of ${ALL.length} songs`;
      const chipHtml = [
        filters.issue ? chipRm("issue", filters.issue) : "",
        filters.gaggle ? chipRm("gaggle", filters.gaggle) : "",
        filters.tune ? chipRm("tune", filters.tune) : "",
        filters.songwriter ? chipRm("songwriter", filters.songwriter) : "",
      ].filter(Boolean).join("");
      resultCount.innerHTML = countHtml + chipHtml;

      pagerInfo.textContent = `Page ${page} of ${totalPages}`;
      prevBtn.disabled = page <= 1;
      nextBtn.disabled = page >= totalPages;

      clearBtn.classList.toggle("hidden", !filters.q);

      syncDropdowns();
    }

    function chipRm(type, val) {
      return ` <button class="lib-chip-rm inline-flex gap-1.5 px-2.5 py-1 bg-mustard rounded-full text-ink font-[800] cursor-pointer text-[13px] border-0 ml-2 hover:bg-red hover:text-white" data-type="${type}">
        ${val} ✕
      </button>`;
    }

    let debounceTimer;
    searchInput.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        filters.q = searchInput.value;
        page = 1;
        render();
      }, 200);
    });

    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      filters.q = "";
      page = 1;
      render();
    });

    sortSelect.addEventListener("change", () => {
      sort = sortSelect.value;
      page = 1;
      render();
    });

    for (const key of ["issue", "gaggle", "tune"]) {
      taxSelects[key]?.addEventListener("change", () => {
        filters[key] = taxSelects[key].value;
        page = 1;
        render();
      });
    }

    document.addEventListener("click", (e) => {
      const resultChip = e.target.closest(".lib-result-chip");
      if (resultChip) {
        filters.issue = resultChip.dataset.issue;
        page = 1;
        render();
        window.scrollTo({ top: 0, behavior: "smooth" });
        return;
      }
      const chipRm = e.target.closest(".lib-chip-rm");
      if (chipRm) {
        filters[chipRm.dataset.type] = "";
        page = 1;
        render();
      }
    });

    prevBtn.addEventListener("click", () => { page--; render(); window.scrollTo(0, 300); });
    nextBtn.addEventListener("click", () => { page++; render(); window.scrollTo(0, 300); });
    resetBtn.addEventListener("click", () => {
      filters = { q: "", issue: "", gaggle: "", tune: "", songwriter: "" };
      searchInput.value = "";
      sort = "a-z";
      sortSelect.value = "a-z";
      page = 1;
      render();
    });

    // Init from URL params (supports linking from /songs/by-issue/, /songs/by-tune/,
    // and from gaggle subsites whose Songs pill passes ?gaggle=<slug>).
    // The lookup is case-insensitive against the actual term names so a
    // slug-form param like ?gaggle=portland resolves to the canonical
    // "Portland" — otherwise the strict equality filter returns 0 results.
    function canonicalize(rawValues, requested) {
      const want = String(requested).toLowerCase();
      return rawValues.find((v) => String(v).toLowerCase() === want) ?? requested;
    }
    const params = new URLSearchParams(window.location.search);
    if (params.get("issue")) {
      const issueNames = [...new Set(ALL.flatMap((s) => s.i))];
      filters.issue = canonicalize(issueNames, params.get("issue"));
    }
    if (params.get("tune")) {
      const tuneNames = [...new Set(ALL.map((s) => s.n).filter(Boolean))];
      filters.tune = canonicalize(tuneNames, params.get("tune"));
    }
    if (params.get("gaggle")) {
      const gaggleNames = [...new Set(ALL.map((s) => s.g).filter(Boolean))];
      filters.gaggle = canonicalize(gaggleNames, params.get("gaggle"));
    }
    if (params.get("songwriter")) {
      const songwriterNames = [...new Set(ALL.map((s) => s.w).filter(Boolean))];
      filters.songwriter = canonicalize(songwriterNames, params.get("songwriter"));
    }
    render();

    // Filter panel: collapsible <details> on mobile, always-open aside on
    // desktop. Same pattern as the footer accordions in BaseLayout.
    (function () {
      const panel = document.querySelector(".lib-filter-panel");
      if (!panel) return;
      const mq = window.matchMedia("(min-width: 768px)");
      const apply = function () { panel.open = mq.matches; };
      apply();
      mq.addEventListener("change", apply);
    })();
  </script>

  <style>
    .lib-filter-panel { width: 100%; }
    .lib-filter-summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: var(--color-card);
      border: 1.5px solid var(--color-muted);
      border-radius: 10px;
      font-family: var(--font-body);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-ink);
    }
    .lib-filter-summary::-webkit-details-marker { display: none; }
    .lib-filter-summary::marker { display: none; }
    .lib-filter-chev {
      transition: transform 0.15s ease;
      font-size: 14px;
    }
    .lib-filter-panel[open] .lib-filter-chev { transform: rotate(180deg); }
  </style>
</BaseLayout>
