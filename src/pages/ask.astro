---
import BaseLayout from "../layouts/BaseLayout.astro";

const SITE_URL = Astro.site?.toString().replace(/\/$/, "") ?? "https://raginggrannies.org";
const TURNSTILE_SITEKEY = import.meta.env.PUBLIC_TURNSTILE_SITEKEY ?? "";

// Example questions surface as clickable chips. Tuned per D045 — short,
// concrete, span the major content types (songs, gaggles, how-to, FAQ).
const examples = [
  "Find a song about water rights",
  "Where can I see the Raging Grannies in action?",
  "Is there a gaggle near me?",
  "How do I start a gaggle?",
  "Who can be a Granny?",
  "How do I submit a song I wrote?",
];

const askSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Ask the website",
  description:
    "Ask a question about the Raging Grannies. Find a song, find a gaggle, find your way in.",
  url: `${SITE_URL}/ask/`,
  publisher: { "@id": `${SITE_URL}#org` },
  inLanguage: "en",
};
---

<BaseLayout
  title="Ask the website"
  description="Ask a question about the Raging Grannies. Find a song, find a gaggle, find your way in."
  structuredData={askSchema}
>
  <article class="max-w-[1100px] mx-auto px-5 md:px-8 pt-10 md:pt-12 pb-20">
    {/* Hero */}
    <header class="text-center pb-10 md:pb-12 border-b border-muted mb-10 md:mb-12">
      <div class="kicker text-red mb-4">Ask the website</div>
      <h1 class="font-display text-ink leading-[.95] mb-5 tracking-tight" style="font-size:clamp(36px,7.5vw,96px)">
        What do you want to know?
      </h1>
      <p class="text-[17px] md:text-[20px] text-text-soft italic max-w-[680px] mx-auto leading-snug">
        Find a song, find a gaggle, find your way in. We'll do our best! And if we can't, we'll connect you to a human Granny.
      </p>
    </header>

    {/* Input */}
    <form id="ask-form" class="max-w-[760px] mx-auto">
      <label for="ask-input" class="sr-only">Your question</label>
      <input
        id="ask-input"
        type="text"
        autocomplete="off"
        autocapitalize="sentences"
        placeholder="Type your question…"
        class="ask-input"
      />
      {TURNSTILE_SITEKEY && (
        <div class="flex justify-center mt-6">
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITEKEY} data-theme="light"></div>
        </div>
      )}
      <div class="flex justify-center mt-6">
        <button type="submit" class="btn btn-primary text-[17px] px-9 py-3" id="ask-submit">
          Ask
        </button>
      </div>
    </form>

    {TURNSTILE_SITEKEY && (
      <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>
    )}

    {/* Example chips */}
    <section class="max-w-[760px] mx-auto mt-12">
      <p class="kicker text-red mb-4 text-center">Try one of these</p>
      <div class="flex flex-wrap gap-2.5 justify-center">
        {examples.map((q) => (
          <button class="example-chip" type="button" data-question={q}>{q}</button>
        ))}
      </div>
    </section>

    {/* Result area — populated by the submit handler. Three states:
        loading, success (answer + sources), error/disabled (friendly
        message + email fallback). */}
    <section id="ask-result" class="max-w-[760px] mx-auto mt-14 hidden">
      <div id="ask-loading" class="hidden text-center py-8">
        <p class="text-text-soft italic text-[17px]">Thinking…</p>
      </div>

      <div id="ask-answer-block" class="hidden">
        <p class="kicker text-red mb-3">Answer</p>
        <div id="ask-answer" class="ask-prose text-[17px] leading-relaxed text-text"></div>
      </div>

      <div id="ask-error-block" class="hidden">
        <div class="border-l-[3px] border-red pl-5 py-2 bg-paper-2 rounded-r-[10px]">
          <p id="ask-error-msg" class="text-[17px] leading-relaxed text-text"></p>
        </div>
      </div>
    </section>

    {/* Permanent fallback */}
    <footer class="mt-16 pt-10 border-t border-muted text-center max-w-[760px] mx-auto">
      <p class="text-[17px] text-text-soft mb-2">
        Still wondering? <a href="mailto:webgranny@raginggrannies.org" class="text-red font-bold no-underline hover:underline">Email a human Granny</a>.
      </p>
      <p class="text-[13px] text-muted italic">
        Your questions help us improve the website. No personal information is collected.
      </p>
    </footer>
  </article>
</BaseLayout>

<style>
  .ask-input {
    width: 100%;
    font-family: var(--font-body);
    font-size: 20px;
    line-height: 1.4;
    padding: 18px 22px;
    border: 1.5px solid var(--color-rule);
    border-radius: 16px;
    background: var(--color-paper);
    color: var(--color-ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .ask-input::placeholder {
    color: var(--color-muted);
    font-style: italic;
  }
  .ask-input:focus {
    outline: none;
    border-color: var(--color-red);
    box-shadow: 0 0 0 3px rgba(226, 42, 44, 0.15);
  }
  .example-chip {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 700;
    padding: 8px 18px;
    border: 1.5px solid var(--color-rule);
    border-radius: 999px;
    background: var(--color-paper);
    color: var(--color-ink);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .example-chip:hover {
    border-color: var(--color-red);
    color: var(--color-red);
  }
  /* :global() so the selector applies to anchors injected via innerHTML
     at runtime — Astro's scoped styles add a per-component data-attribute
     that dynamically-created elements don't have, so descendant rules
     have to opt out of scoping or they won't match. Tailwind's preflight
     also resets anchor color/decoration to inherit, which is why these
     anchors otherwise look like plain text. */
  .ask-prose :global(a) {
    color: var(--color-red);
    text-decoration: none;
    border-bottom: 1.5px solid var(--color-red);
    font-weight: 600;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .ask-prose :global(a:hover) {
    background: var(--color-red);
    color: var(--color-on-dark);
  }
  .ask-prose :global(strong) {
    color: var(--color-ink);
  }
  .ask-prose {
    white-space: pre-wrap;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const input = document.getElementById("ask-input");
    const submit = document.getElementById("ask-submit");
    const form = document.getElementById("ask-form");
    const result = document.getElementById("ask-result");
    const loading = document.getElementById("ask-loading");
    const answerBlock = document.getElementById("ask-answer-block");
    const answerEl = document.getElementById("ask-answer");
    const errorBlock = document.getElementById("ask-error-block");
    const errorMsg = document.getElementById("ask-error-msg");
    if (!input || !submit || !form || !result || !loading || !answerBlock || !answerEl || !errorBlock || !errorMsg) return;

    document.querySelectorAll(".example-chip").forEach((chip) => {
      chip.addEventListener("click", () => {
        input.value = chip.dataset.question || chip.textContent;
        input.focus();
      });
    });

    function escapeHtml(s) {
      return s
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");
    }

    // Tiny markdown-lite renderer for Claude's response. Escape first,
    // then transform the small set of constructs we expect: [text](url)
    // links (absolute or site-relative), bare URLs (the "Sources:" list
    // uses these), and **bold**. Anything else falls through as
    // preformatted text — .ask-prose has white-space: pre-wrap so
    // paragraph breaks and bullet lines render as written.
    function renderMarkdownLite(text) {
      let html = escapeHtml(text);

      // 1. Markdown links [label](url) — absolute https?:// or site-relative /path
      html = html.replace(
        /\[([^\]]+)\]\((\/[^)\s]+|https?:\/\/[^)\s]+)\)/g,
        (_m, label, url) => `<a href="${url}" rel="noopener">${label}</a>`,
      );

      // 2. Bare URLs (e.g. in the "Sources:" list). Must be preceded by
      // whitespace / start-of-string / `(` / `>` so URLs already inside
      // href="…" attributes from step 1 don't double-process.
      html = html.replace(
        /(^|[\s>(])(https?:\/\/[^\s<)"]+)/g,
        (_m, before, url) => `${before}<a href="${url}" rel="noopener">${url}</a>`,
      );

      // 3. Bold
      html = html.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");

      return html;
    }

    function showLoading() {
      result.classList.remove("hidden");
      loading.classList.remove("hidden");
      answerBlock.classList.add("hidden");
      errorBlock.classList.add("hidden");
      submit.disabled = true;
      submit.textContent = "Asking…";
    }
    function showAnswer(text) {
      loading.classList.add("hidden");
      errorBlock.classList.add("hidden");
      answerEl.innerHTML = renderMarkdownLite(text);
      answerBlock.classList.remove("hidden");
      submit.disabled = false;
      submit.textContent = "Ask";
    }
    function showError(message) {
      loading.classList.add("hidden");
      answerBlock.classList.add("hidden");
      errorMsg.innerHTML = renderMarkdownLite(message);
      errorBlock.classList.remove("hidden");
      submit.disabled = false;
      submit.textContent = "Ask";
    }

    function resetTurnstile() {
      if (window.turnstile && typeof window.turnstile.reset === "function") {
        window.turnstile.reset();
      }
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const question = input.value.trim();
      if (!question) return;

      // Turnstile token (when widget is rendered). The widget injects a
      // hidden input named cf-turnstile-response into the form once the
      // visitor passes the challenge.
      const tokenEl = form.querySelector('[name="cf-turnstile-response"]');
      const turnstileToken = tokenEl && tokenEl.value ? tokenEl.value : "";

      showLoading();
      result.scrollIntoView({ behavior: "smooth", block: "start" });

      try {
        const res = await fetch("/api/ask", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ question, turnstileToken }),
        });
        const data = await res.json();
        if (!res.ok || data.error) {
          showError(
            data.message ||
              "Something went wrong. Email [a human Granny](mailto:webgranny@raginggrannies.org).",
          );
          resetTurnstile();
          return;
        }
        showAnswer(data.answer || "");
        resetTurnstile();
      } catch (err) {
        showError(
          "Couldn't reach the server. Email [a human Granny](mailto:webgranny@raginggrannies.org) and we'll get back to you.",
        );
        resetTurnstile();
      }
    });
  });
</script>
