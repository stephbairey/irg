function ytId(url: string): string {
  const m = url.match(/(?:v=|\/embed\/|youtu\.be\/)([\w-]{11})/);
  return m?.[1] ?? "";
}
---

<BaseLayout title="Grannies on Camera">
  <article class="max-w-[1400px] mx-auto px-5 md:px-8 pt-10 md:pt-12 pb-20">
    {/* Hero */}
    <header class="text-center pb-8 md:pb-10 border-b border-muted mb-12 md:mb-14">
      <div class="kicker text-red mb-4">From the airwaves</div>
      <h1 class="font-display text-ink leading-[.95] mb-5 tracking-tight" style="font-size:clamp(36px,7.5vw,96px)">
        Grannies on Camera
      </h1>
      <p class="text-[17px] md:text-[20px] text-text-soft italic max-w-[760px] mx-auto leading-snug">
        We've been singing truth to power since 1987, and thanks to the internet, you can hear us from anywhere. Below you'll find YouTube channels from gaggles across the network, plus a few of our favorite performances. Fair warning: we're better at protest than production value.
      </p>
    </header>

    {/* Channel directory */}
    <section class="max-w-[1080px] mx-auto">
      <div class="kicker text-red mb-2">Directory</div>
      <h2 class="font-display text-ink text-[40px] leading-tight mb-8">Granny Channels on YouTube</h2>

      {channels.map((country) => (
        <div class="vid-country">
          <h3 class="vid-country-title">{country.country}</h3>
          <div class="vid-grid">
            {country.states.map((sg) => (
              <div class="vid-region">
                <div class="vid-region-name">{sg.state}</div>
                <ul class="vid-list">
                  {sg.channels.map((ch) => (
                    <li>
                      <a
                        href={ch.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="vid-link"
                      >
                        {ch.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    {/* Featured videos */}
    <section class="max-w-[860px] mx-auto mt-20 pt-12 border-t border-muted">
      <div class="kicker text-red mb-2">Greatest hits</div>
      <h2 class="font-display text-ink text-[40px] leading-tight mb-10">Featured Videos</h2>

      <div class="space-y-16">
        {featured.map((v) => {
          const id = ytId(v.url);
          return (
            <div>
              <div class="kicker text-red mb-2">{v.gaggle}</div>
              <h3 class="font-display text-ink text-[28px] leading-tight mb-5">{v.title}</h3>
              <div class="vid-embed">
                {id ? (
                  <iframe
                    src={`https://www.youtube-nocookie.com/embed/${id}`}
                    title={`${v.gaggle}: ${v.title}`}
                    loading="lazy"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                  ></iframe>
                ) : (
                  <a href={v.url} target="_blank" rel="noopener noreferrer" class="vid-fallback">
                    Watch on YouTube
                  </a>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  /* Channel directory — mirrors the Find a Gaggle pattern */
  .vid-country + .vid-country { margin-top: 40px; }
  .vid-country-title {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--color-ink);
    margin: 0 0 16px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--color-red);
  }
  .vid-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px 36px;
  }
  @media (max-width: 900px) { .vid-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .vid-grid { grid-template-columns: 1fr; } }
  .vid-region-name {
    font: 800 11px/1.2 var(--font-body);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 8px;
  }
  .vid-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
    font-size: 16px;
    line-height: 1.45;
  }
  .vid-link {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .vid-link:hover {
    color: var(--color-red);
    border-bottom-color: var(--color-red);
  }

  /* Featured embeds — 16:9, lazy-loaded, gentle frame in the brand palette */
  .vid-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-paper-2);
    border: 1px solid var(--color-muted);
    border-radius: 10px;
    overflow: hidden;
  }
  .vid-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .vid-fallback {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    color: var(--color-red);
    font-weight: 800;
    text-decoration: underline;
  }
</style>
