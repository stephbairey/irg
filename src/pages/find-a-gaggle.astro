---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

interface Gaggle {
  name: string;
  region: string;
  country: string;
  lat: number;
  lng: number;
  aka: string;   // display name, e.g. "Antigonish Raging Grannies"
  slug: string;  // subsite slug, e.g. "antigonish"
}

const DATA = resolve(process.cwd(), "data/gaggle-locations.json");
let gaggles: Gaggle[] = [];
if (existsSync(DATA)) {
  try {
    const raw = JSON.parse(readFileSync(DATA, "utf8"));
    if (Array.isArray(raw)) {
      gaggles = (raw as Gaggle[]).filter(
        (g) =>
          g &&
          typeof g.name === "string" &&
          typeof g.lat === "number" &&
          typeof g.lng === "number" &&
          typeof g.slug === "string" &&
          typeof g.aka === "string",
      );
    }
  } catch (err) {
    console.warn(`[find-a-gaggle] could not parse ${DATA}: ${(err as Error).message}`);
  }
}

// Set of slugs that have a live subsite. Used to gate whether each directory
// row + map popup links out, vs. renders as plain text. The link target stays
// the planned <slug>.raginggrannies.org pattern; this just suppresses the link
// for gaggles that don't have a subsite yet.
const SUBSITES_PATH = resolve(process.cwd(), "data/subsites.json");
const liveSlugs = new Set<string>();
if (existsSync(SUBSITES_PATH)) {
  try {
    const raw = JSON.parse(readFileSync(SUBSITES_PATH, "utf8"));
    if (Array.isArray(raw)) {
      for (const s of raw) {
        if (s && typeof s.slug === "string") liveSlugs.add(s.slug);
      }
    }
  } catch (err) {
    console.warn(`[find-a-gaggle] could not parse ${SUBSITES_PATH}: ${(err as Error).message}`);
  }
}

const total = gaggles.length;

// Group by country → region for the directory list. Within each region,
// gaggles are sorted alphabetically by name.
const byCountry: Record<string, Record<string, Gaggle[]>> = {};
for (const g of gaggles) {
  byCountry[g.country] ??= {};
  byCountry[g.country][g.region] ??= [];
  byCountry[g.country][g.region].push(g);
}
for (const country of Object.keys(byCountry)) {
  for (const region of Object.keys(byCountry[country])) {
    byCountry[country][region].sort((a, b) => a.name.localeCompare(b.name));
  }
}
// Country order: USA first, Canada second, then the rest alphabetical.
const COUNTRY_ORDER = ["United States", "Canada"];
const countries = Object.keys(byCountry).sort((a, b) => {
  const ai = COUNTRY_ORDER.indexOf(a);
  const bi = COUNTRY_ORDER.indexOf(b);
  if (ai !== -1 && bi !== -1) return ai - bi;
  if (ai !== -1) return -1;
  if (bi !== -1) return 1;
  return a.localeCompare(b);
});

// Send only what the map needs. JSON-escape "<" so the embedded
// <script type="application/json"> block can never break out.
const mapPayload = JSON.stringify(
  gaggles.map((g) => ({
    name: g.name,
    aka: g.aka,
    slug: g.slug,
    region: g.region,
    country: g.country,
    lat: g.lat,
    lng: g.lng,
    hasSubsite: liveSlugs.has(g.slug),
  })),
).replace(/</g, "\\u003c");

const SITE_URL = Astro.site?.toString().replace(/\/$/, "") ?? "https://raginggrannies.org";

const gaggleListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Raging Grannies Gaggle Directory",
  numberOfItems: total,
  itemListElement: gaggles.map((g, idx) => ({
    "@type": "ListItem",
    position: idx + 1,
    item: {
      "@type": "Organization",
      name: g.aka,
      address: {
        "@type": "PostalAddress",
        addressRegion: g.region,
        addressCountry: g.country,
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: g.lat,
        longitude: g.lng,
      },
      parentOrganization: { "@id": `${SITE_URL}#org` },
      url: `${SITE_URL}/find-a-gaggle/#${g.slug}`,
    },
  })),
};
---

<BaseLayout title="Find a Gaggle" structuredData={gaggleListSchema}>
  <article class="max-w-[1400px] mx-auto px-8 pt-12 pb-20">
    {/* Hero */}
    <header class="text-center pb-10 mb-10 border-b border-muted">
      <div class="kicker text-red mb-4">The Network</div>
      <h1 class="font-display text-ink leading-[.95] mb-5 tracking-tight" style="font-size:clamp(56px,8vw,112px)">
        Find a Gaggle
      </h1>
      <p class="text-[20px] text-text-soft italic max-w-[760px] mx-auto leading-snug">
        {total > 0 ? (
          <>There are {total} gaggles of Raging Grannies across North America and around the world. Find one near you, or start your own.</>
        ) : (
          <>Gaggles span North America and beyond. The map's loading. Find one near you, or start your own.</>
        )}
      </p>
    </header>

    {/* Map */}
    <div class="map-wrap">
      <div id="gaggle-map" aria-label="Map of Raging Grannies gaggles"></div>
      <noscript>
        <div class="map-noscript">
          The interactive map needs JavaScript. The full directory of gaggles is below.
        </div>
      </noscript>
    </div>

    {/* Directory */}
    <section class="max-w-[1080px] mx-auto mt-16">
      <div class="kicker text-red mb-2">Directory</div>
      <h2 class="font-display text-ink text-[40px] leading-tight mb-8">All gaggles</h2>

      {countries.length === 0 ? (
        <div class="text-center py-12 px-8 bg-paper-2 border border-dashed border-rule rounded-[10px] grid gap-2 max-w-[640px] mx-auto">
          <b class="font-display text-ink text-[24px] font-normal">Directory loading…</b>
          <span class="text-[14px] text-text-soft">Locations are being added. Check back soon.</span>
        </div>
      ) : (
        countries.map((country) => {
          const regions = Object.keys(byCountry[country]).sort((a, b) => a.localeCompare(b));
          return (
            <div class="dir-country">
              <h3 class="dir-country-title">{country}</h3>
              <div class="dir-grid">
                {regions.map((region) => (
                  <div class="dir-region">
                    <div class="dir-region-name">{region}</div>
                    <ul class="dir-list">
                      {byCountry[country][region].map((g) => (
                        <li>
                          {liveSlugs.has(g.slug) ? (
                            <a
                              href={`https://${g.slug}.raginggrannies.org/`}
                              class="dir-link"
                              rel="noopener"
                            >{g.aka || g.name}</a>
                          ) : (
                            <span class="dir-name">{g.aka || g.name}</span>
                          )}
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          );
        })
      )}
    </section>

    {/* CTA */}
    <section class="mt-20">
      <div class="cta-card">
        <div>
          <div class="kicker text-mustard mb-2">A gaggle of one</div>
          <h3 class="font-display text-on-dark text-[34px] leading-tight mb-3">
            Don't see a gaggle near you? Start one.
          </h3>
          <p class="text-on-dark/85 leading-relaxed max-w-[56ch]">
            Two or three women, a good tune, and an issue worth singing about: that's the recipe. Our starter kit walks you through naming a gaggle, writing your first song, and showing up.
          </p>
        </div>
        <a href="/start-a-gaggle/" class="cta-btn">
          Get the starter kit <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </article>

  {/* Data block: read by the bundled script below. type=application/json keeps it inert. */}
  <script type="application/json" id="gaggle-data" set:html={mapPayload}></script>

  <script>
    // Map init runs only on this page — Astro bundles Mapbox GL JS into a page-scoped chunk.
    import mapboxgl from "mapbox-gl";
    import "mapbox-gl/dist/mapbox-gl.css";

    (() => {
      const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
      if (!token) {
        console.warn("[find-a-gaggle] PUBLIC_MAPBOX_TOKEN missing — map will not load.");
        return;
      }
      mapboxgl.accessToken = token;

      const dataEl = document.getElementById("gaggle-data");
      if (!dataEl) return;
      let gaggles = [];
      try {
        gaggles = JSON.parse(dataEl.textContent || "[]");
      } catch {
        return;
      }

      const el = document.getElementById("gaggle-map");
      if (!el) return;

      const map = new mapboxgl.Map({
        container: el,
        style: "mapbox://styles/webgranny/cmoj09evr000801ra14qg2brh",
        center: [-98.5, 39.5], // [lng, lat] — ~ Kansas, centers on continental North America
        zoom: 3,
        attributionControl: true,
      });
      map.addControl(new mapboxgl.NavigationControl({ showCompass: false }), "top-right");

      // Hide road / transit layers at runtime. Works on classic Studio styles
      // (where individual layers are exposed); Mapbox Standard styles seal
      // their internals so this is a no-op on Standard — confirm via console.
      map.on("style.load", () => {
        const ROAD_RE = /road|bridge|tunnel|motorway|highway|trunk|street|aeroway|transit|rail|subway|ferry/i;
        const layers = map.getStyle().layers || [];
        let hidden = 0;
        const hiddenIds = [];
        for (const layer of layers) {
          const id = layer.id || "";
          const sourceLayer = layer["source-layer"] || "";
          if (ROAD_RE.test(id) || ROAD_RE.test(sourceLayer)) {
            try {
              map.setLayoutProperty(layer.id, "visibility", "none");
              hidden++;
              hiddenIds.push(layer.id);
            } catch {
              // Standard styles may reject mutation; silently skip.
            }
          }
        }
        // eslint-disable-next-line no-console
        console.log(
          `[find-a-gaggle] hid ${hidden} road-related layers of ${layers.length} total`,
          hiddenIds
        );
      });

      function escHtml(s) {
        return String(s ?? "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;");
      }

      for (const g of gaggles) {
        const markerEl = document.createElement("div");
        markerEl.className = "gaggle-marker";

        const subsiteUrl = `https://${encodeURIComponent(g.slug)}.raginggrannies.org/`;
        const contactHtml = g.hasSubsite
          ? `<div class="gp-contact"><a href="${escHtml(subsiteUrl)}">Visit this gaggle's website →</a></div>`
          : `<div class="gp-contact gp-contact-soft">Site coming soon</div>`;
        const popup = new mapboxgl.Popup({
          offset: 14,
          closeButton: false,
          maxWidth: "280px",
        }).setHTML(`
          <div class="gaggle-popup">
            <div class="gp-name">${escHtml(g.aka || g.name)}</div>
            <div class="gp-where">${escHtml(g.region)}, ${escHtml(g.country)}</div>
            ${contactHtml}
          </div>
        `);

        new mapboxgl.Marker({ element: markerEl })
          .setLngLat([g.lng, g.lat])
          .setPopup(popup)
          .addTo(map);
      }
    })();
  </script>

  <style is:global>
    .map-wrap {
      max-width: 1400px;
      margin: 0 auto;
      border: 1px solid var(--color-muted);
      border-radius: 10px;
      overflow: hidden;
      background: var(--color-paper-2);
    }
    #gaggle-map {
      height: 560px;
      width: 100%;
      background: var(--color-paper-2);
    }
    @media (max-width: 720px) {
      #gaggle-map { height: 340px; }
    }
    .map-noscript {
      padding: 24px;
      text-align: center;
      color: var(--color-text-soft);
      font-style: italic;
    }
    /* Gaggle marker — circle dot in the brand red over an ink stroke. */
    .gaggle-marker {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: #E22A2C;
      border: 1.25px solid #2A1847;
      box-shadow: 0 1px 3px rgba(42, 24, 71, 0.35);
      cursor: pointer;
      transition: transform 0.15s ease;
    }
    .gaggle-marker:hover {
      transform: scale(1.3);
    }
    /* Mapbox popup themed to match the Bulletin language */
    .mapboxgl-popup-content {
      border-radius: 8px;
      box-shadow: 0 6px 24px rgba(42, 24, 71, 0.18);
      padding: 14px 16px 12px;
      font-family: var(--font-body);
      color: var(--color-text);
    }
    .mapboxgl-popup-tip {
      border-top-color: var(--color-on-dark);
      border-bottom-color: var(--color-on-dark);
    }
    .gaggle-popup .gp-name {
      font-family: var(--font-display);
      font-size: 20px;
      line-height: 1.1;
      color: var(--color-ink);
      margin-bottom: 4px;
    }
    .gaggle-popup .gp-where {
      font: 700 11px/1.2 var(--font-body);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 10px;
    }
    .gaggle-popup .gp-contact {
      font-size: 13px;
      color: var(--color-text-soft);
    }
    .gaggle-popup .gp-contact a {
      color: var(--color-red);
      font-weight: 700;
      text-decoration: none;
      border-bottom: 1.5px solid var(--color-red);
    }
    .gaggle-popup .gp-contact a:hover {
      background: var(--color-red);
      color: var(--color-on-dark);
    }

    /* Directory */
    .dir-country + .dir-country { margin-top: 40px; }
    .dir-country-title {
      font-family: var(--font-display);
      font-size: 32px;
      color: var(--color-ink);
      margin: 0 0 16px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--color-red);
    }
    .dir-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px 36px;
    }
    @media (max-width: 900px) { .dir-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 560px) { .dir-grid { grid-template-columns: 1fr; } }
    .dir-region-name {
      font: 800 11px/1.2 var(--font-body);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 8px;
    }
    .dir-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 4px;
      font-size: 16px;
      line-height: 1.45;
      color: var(--color-text);
    }
    .dir-link {
      color: var(--color-red);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.15s ease;
    }
    .dir-link:hover, .dir-link:focus-visible {
      border-bottom-color: var(--color-red);
      outline: none;
    }
    .dir-name {
      color: var(--color-text);
    }
    .gaggle-popup .gp-contact-soft {
      color: var(--color-muted);
      font-style: italic;
    }

    /* CTA */
    .cta-card {
      max-width: 1080px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
      padding: 36px 40px;
      background: var(--color-ink);
      color: var(--color-on-dark);
      border-radius: 14px;
    }
    @media (max-width: 720px) {
      .cta-card { grid-template-columns: 1fr; gap: 20px; padding: 28px 24px; }
    }
    .cta-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 14px 22px;
      border-radius: 999px;
      background: var(--color-red);
      color: var(--color-on-dark);
      font: 800 15px/1 var(--font-body);
      letter-spacing: 0.02em;
      text-decoration: none;
      transition: background 0.15s;
      white-space: nowrap;
    }
    .cta-btn:hover { background: #c82022; }
  </style>
</BaseLayout>
