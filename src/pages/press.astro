---
import BaseLayout from "../layouts/BaseLayout.astro";

// Placeholder press data — will be wired to a real Google Alerts pipeline later.
// Shape matches the design handoff's PressItem type.
const PRESS_ITEMS = [
  {
    title: 'Protesters Accuse UCP Of "Gaslighting" Immigrants Before Referendum',
    source: "Bridge City News",
    date: "2026-04-17",
    region: "Alberta",
    gaggle: "Lethbridge",
    blurb:
      "An advocacy group known as the Raging Grannies were in north Lethbridge on Friday to let their voices be heard in opposition to the provincial referendum questions.",
    url: "#",
  },
  {
    title: "Raging Grannies Street Rally Protests Immigration Referendum Questions",
    source: "Lethbridge News Now",
    date: "2026-04-17",
    region: "Alberta",
    gaggle: "Lethbridge",
    blurb:
      "The Lethbridge Raging Grannies are back at it on April 17, with a street rally to protest several questions included on the upcoming provincial ballot.",
    url: "#",
  },
  {
    title: "Singing Seniors Stage Climate Sit-In Outside State Capitol",
    source: "Madison Cap Times",
    date: "2026-04-11",
    region: "Wisconsin",
    gaggle: "Madison",
    blurb:
      "Armed with guitars, tambourines, and a songbook three decades deep, the Madison Raging Grannies held a four-hour vigil on the Capitol steps demanding action on the state energy bill.",
    url: "#",
  },
  {
    title: '"We Sing Because We Refuse To Shut Up": Raging Grannies Mark 39 Years',
    source: "Times Colonist",
    date: "2026-04-04",
    region: "British Columbia",
    gaggle: "Victoria",
    blurb:
      "The original Victoria gaggle gathered at Centennial Square to celebrate nearly four decades of satirical protest song, joined by members as young as 58 and as old as 94.",
    url: "#",
  },
  {
    title: "Local Grannies Take Housing Fight To City Hall, With Harmonies",
    source: "The Tyee",
    date: "2026-03-28",
    region: "British Columbia",
    gaggle: "Vancouver",
    blurb:
      "A dozen flowered-hat activists interrupted Tuesday's zoning hearing with a three-part rewrite of a beloved folk tune, arguing for tenant protections in the Downtown Eastside.",
    url: "#",
  },
  {
    title: "Grannies, Guitars And Grievances: Inside A Satirical Protest Movement",
    source: "CBC Radio · The Current",
    date: "2026-03-22",
    region: "National",
    gaggle: "Multiple",
    blurb:
      "A half-hour radio feature visiting three gaggles across the country, tracing the origins of the movement from a 1987 anti-nuclear protest in Victoria to today's climate marches.",
    url: "#",
  },
  {
    title: 'Seattle Raging Grannies Rewrite "My Blockade" For Port Protest',
    source: "KUOW",
    date: "2026-03-14",
    region: "Washington",
    gaggle: "Seattle",
    blurb:
      "Songwriter Jo-Hanna Reed debuted the new lyrics at Saturday's dockside demonstration, drawing on the Dixie Cups melody her gaggle has been adapting for five years.",
    url: "#",
  },
  {
    title: "A Chorus Of Nanas: Portland Gaggle Joins Pipeline Blockade",
    source: "Willamette Week",
    date: "2026-03-05",
    region: "Oregon",
    gaggle: "Portland",
    blurb:
      "Twelve members of the Portland Raging Grannies linked arms across the access road before dawn, singing until the police finally asked, politely, for permission to arrest them.",
    url: "#",
  },
  {
    title: "Green Bay Grannies Honor Labor Day With 1,500-Strong Sing-Along",
    source: "Green Bay Press-Gazette",
    date: "2026-02-14",
    region: "Wisconsin",
    gaggle: "Green Bay",
    blurb:
      'Organizer Susan Dutton led the crowd through three original labor songs written by her gaggle, including "The Modern Workers Song," a reimagining of a 1964 protest classic.',
    url: "#",
  },
  {
    title: "Opinion: The Raging Grannies Have Always Understood Assignment",
    source: "The Walrus",
    date: "2026-01-30",
    region: "National",
    gaggle: null,
    blurb:
      "A culture essay arguing that satirical protest song, dismissed for decades as quaint, has turned out to be one of the most durable forms of civic engagement in North America.",
    url: "#",
  },
  {
    title: "Raging Grannies Arrested At Nuclear Weapons Lab Gate",
    source: "East Bay Express",
    date: "2026-01-18",
    region: "California",
    gaggle: "East Bay",
    blurb:
      "Seven women in flowered hats and sensible shoes were cited and released after a two-hour sit-in at the Livermore Lab gate, marking the 40th anniversary of the Nevada Test Site protests.",
    url: "#",
  },
  {
    title: "Calgary Grannies Launch Anti-Coal Songbook With Live Performance",
    source: "CBC Calgary",
    date: "2026-01-09",
    region: "Alberta",
    gaggle: "Calgary",
    blurb:
      "The new 22-song collection, released free online, reworks Alberta folk standards with lyrics targeting the province's recently revived coal mining policy.",
    url: "#",
  },
];

// Sort newest-first for the SSR baseline.
PRESS_ITEMS.sort((a, b) => b.date.localeCompare(a.date));

const itemsJson = JSON.stringify(PRESS_ITEMS);

// Live-feed copy
const latest = PRESS_ITEMS[0];
const daysSince = Math.floor(
  (Date.now() - new Date(latest.date + "T00:00:00").getTime()) / 86_400_000,
);
const daysSinceLabel =
  daysSince === 0
    ? "today"
    : daysSince === 1
      ? "yesterday"
      : `${daysSince} days ago`;
---

<BaseLayout title="Press">
  <article class="press-page">
    <!-- Hero -->
    <section class="bg-paper border-b-[3px] border-double border-ink">
      <div class="max-w-[1240px] mx-auto px-10 pt-12 pb-12">
        <div class="flex justify-between gap-6 flex-wrap text-muted font-bold text-xs tracking-[.12em] uppercase border-b border-rule pb-3.5 mb-9">
          <span>The Clippings Desk</span>
          <span>Auto-updated via Google Alerts</span>
          <span>{PRESS_ITEMS.length} stories on file</span>
        </div>

        <div class="grid grid-cols-[1.8fr_1fr] gap-14 items-start">
          <!-- Left: title + dek + live feed -->
          <div>
            <div class="kicker text-red mb-4">Press &amp; Coverage</div>
            <h1 class="font-display text-ink leading-[.92] tracking-tight" style="font-size:clamp(64px,9vw,128px)">
              In the News
            </h1>
            <p class="text-[20px] leading-[1.5] text-text mt-5 max-w-[56ch]">
              Every mention of <em class="text-ink not-italic font-semibold italic">Raging Grannies</em> across the North American press — auto-clipped and sorted newest first. If something's missing, the alert bot probably missed it; <a href="mailto:press@raginggrannies.org?subject=Press%20mention" class="press-inline-link">send it our way</a>.
            </p>

            <div class="press-live mt-7">
              <span class="press-live-dot" aria-hidden="true"></span>
              <span>
                <b class="text-ink font-extrabold">Live feed.</b>
                Latest clipping added <span id="press-days-since">{daysSinceLabel}</span> — <em class="text-ink-soft italic font-semibold" id="press-latest-source">{latest.source}</em>.
              </span>
            </div>
          </div>

          <!-- Right: photo + press kit card -->
          <aside>
            <figure class="press-hero-photo">
              <img src="/granny-movement.jpg" alt="A Raging Grannies gaggle posed in front of a state capitol" class="w-full h-[220px] object-cover" style="filter:saturate(.9) contrast(1.02)" />
              <figcaption class="font-bold text-[11px] tracking-[.08em] uppercase text-ink text-center py-3 px-1">
                The Madison gaggle, post-rally · 2025
              </figcaption>
            </figure>

            <div class="bg-ink text-on-dark p-7 pt-7 pb-6 rounded-[10px] mt-5">
              <div class="kicker text-mustard mb-2">For Journalists</div>
              <div class="font-display text-on-dark text-[40px] leading-none mb-5">Press Kit</div>
              <ul class="list-none p-0 m-0 grid gap-0.5 mb-5">
                <li><a href="#" class="press-kit-link">Photography (CC-BY) <span aria-hidden="true">→</span></a></li>
                <li><a href="#" class="press-kit-link">Fact sheet &amp; timeline <span aria-hidden="true">→</span></a></li>
                <li><a href="#" class="press-kit-link">Spokesperson directory <span aria-hidden="true">→</span></a></li>
              </ul>
              <div class="pt-4 border-t border-white/15">
                <div class="font-bold text-[11px] tracking-[.14em] uppercase text-ink-lilac mb-1.5">Media inquiries</div>
                <a href="mailto:press@raginggrannies.org" class="press-kit-mail">press@raginggrannies.org</a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- Controls (sticky) -->
    <section class="press-controls sticky top-[73px] z-30 bg-paper border-b border-rule">
      <div class="max-w-[1240px] mx-auto px-10 py-6">
        <div class="flex gap-4 items-center flex-wrap mb-5">
          <div class="press-search">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-muted flex-none" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><line x1="20" y1="20" x2="16.5" y2="16.5"/></svg>
            <input type="text" id="press-search-input" placeholder="Search by title, outlet, or blurb…" />
            <button id="press-search-clear" class="hidden text-red font-extrabold text-[13px] px-2 py-1 bg-transparent border-0 cursor-pointer">Clear</button>
          </div>
          <div class="press-sort">
            <span class="font-extrabold text-[11px] tracking-[.14em] uppercase text-muted">Sort</span>
            <div class="relative">
              <select id="press-sort-select" class="appearance-none border-0 outline-none bg-transparent font-semibold text-sm text-text cursor-pointer pr-5">
                <option value="newest">Newest first</option>
                <option value="oldest">Oldest first</option>
                <option value="source">By outlet (A–Z)</option>
              </select>
              <svg viewBox="0 0 24 24" class="absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-text pointer-events-none" fill="none" stroke="currentColor" stroke-width="2"><path d="m6 9 6 6 6-6"/></svg>
            </div>
          </div>
        </div>

        <div id="press-regions" class="flex gap-2 flex-wrap" role="tablist"></div>
      </div>
    </section>

    <!-- Clippings list -->
    <section class="bg-paper">
      <div class="max-w-[1240px] mx-auto px-10 pt-10 pb-20">
        <div class="flex justify-between items-baseline font-extrabold text-xs tracking-[.12em] uppercase text-muted mb-6">
          <span id="press-count"></span>
          <span id="press-active-region">All regions</span>
        </div>

        <div id="press-empty" class="hidden text-center py-16 px-10 bg-paper-2 border border-dashed border-rule rounded-[10px] grid gap-2">
          <b class="font-display text-ink text-[28px] font-normal">No clippings yet.</b>
          <span class="text-[15px] text-text-soft">Nothing matches that filter. Try a different region or search term.</span>
        </div>

        <div id="press-groups"></div>

        <div class="press-foot-note mt-14">
          <div>
            <b class="text-ink font-extrabold">How this page works.</b>
            A Google Alert for <em class="text-ink italic">"Raging Grannies"</em> pipes new coverage into the site a few times a day. We review it — filtering out coincidences and reruns — and the rest lands here automatically, oldest at the bottom. No editors, no curated narrative. Just what the press is saying.
          </div>
          <a href="/rss.xml" class="press-foot-rss">
            Subscribe to the feed <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </article>

  <script define:vars={{ itemsJson }}>
    const ALL = JSON.parse(itemsJson);

    const $ = (s) => document.querySelector(s);
    const searchInput = $("#press-search-input");
    const clearBtn = $("#press-search-clear");
    const sortSelect = $("#press-sort-select");
    const regionsEl = $("#press-regions");
    const groupsEl = $("#press-groups");
    const countEl = $("#press-count");
    const activeRegionEl = $("#press-active-region");
    const emptyEl = $("#press-empty");

    let state = { q: "", region: "All", sort: "newest" };

    function escAttr(s) {
      return String(s).replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }
    function escHtml(s) {
      return escAttr(s);
    }
    function fmtDate(iso) {
      return new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
        month: "long", day: "numeric", year: "numeric",
      });
    }
    function monthKey(iso) {
      return new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
        month: "long", year: "numeric",
      });
    }

    // Build region chips from data, "All" first, others by count desc.
    const regionCounts = {};
    for (const i of ALL) regionCounts[i.region] = (regionCounts[i.region] || 0) + 1;
    const regions = [["All", ALL.length]].concat(
      Object.entries(regionCounts).sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0])),
    );
    function renderRegions() {
      regionsEl.innerHTML = regions
        .map(([name, count]) => {
          const active = state.region === name ? "is-active" : "";
          return `<button type="button" class="press-region ${active}" data-region="${escAttr(name)}">${escHtml(name)}<span>${count}</span></button>`;
        })
        .join("");
    }
    regionsEl.addEventListener("click", (e) => {
      const btn = e.target.closest(".press-region");
      if (!btn) return;
      state.region = btn.dataset.region;
      renderRegions();
      renderList();
    });

    function applyFilters() {
      const q = state.q.toLowerCase();
      let items = ALL.filter((i) => {
        if (state.region !== "All" && i.region !== state.region) return false;
        if (q) {
          const hay = (i.title + " " + i.source + " " + i.blurb).toLowerCase();
          if (!hay.includes(q)) return false;
        }
        return true;
      });
      if (state.sort === "newest") items.sort((a, b) => b.date.localeCompare(a.date));
      else if (state.sort === "oldest") items.sort((a, b) => a.date.localeCompare(b.date));
      else if (state.sort === "source") items.sort((a, b) => a.source.localeCompare(b.source));
      return items;
    }

    function renderList() {
      const items = applyFilters();
      countEl.textContent = `${items.length} clipping${items.length === 1 ? "" : "s"}`;
      activeRegionEl.textContent = state.region === "All" ? "All regions" : state.region;
      emptyEl.classList.toggle("hidden", items.length > 0);
      clearBtn.classList.toggle("hidden", !state.q);

      if (items.length === 0) {
        groupsEl.innerHTML = "";
        return;
      }

      // Group by month (only meaningful when sorted by date).
      const groupByMonth = state.sort !== "source";
      let html = "";
      if (groupByMonth) {
        const groups = [];
        let current = null;
        for (const item of items) {
          const k = monthKey(item.date);
          if (!current || current.key !== k) {
            current = { key: k, items: [] };
            groups.push(current);
          }
          current.items.push(item);
        }
        for (const g of groups) {
          html += renderGroupHeader(g.key, g.items.length);
          html += `<ol class="press-list">${g.items.map(renderItem).join("")}</ol>`;
        }
      } else {
        html += `<ol class="press-list">${items.map(renderItem).join("")}</ol>`;
      }
      groupsEl.innerHTML = html;
    }

    function renderGroupHeader(label, count) {
      return `
        <div class="press-group-head">
          <h3 class="press-group-title">${escHtml(label)}</h3>
          <span class="press-group-count">${count} stor${count === 1 ? "y" : "ies"}</span>
        </div>`;
    }

    function renderItem(i) {
      const gaggle = i.gaggle ? `<span class="press-dot-sep" aria-hidden="true">·</span><span class="press-gaggle">${escHtml(i.gaggle)} gaggle</span>` : "";
      return `
        <li class="press-item">
          <a href="${escAttr(i.url)}" class="press-item-link" target="_blank" rel="noopener">
            <div class="press-item-meta">
              <span class="press-source">${escHtml(i.source)}</span>
              <span class="press-dot-sep" aria-hidden="true">·</span>
              <time>${fmtDate(i.date)}</time>
              ${gaggle}
            </div>
            <h4 class="press-item-title">${escHtml(i.title)}</h4>
            <p class="press-item-blurb">${escHtml(i.blurb)}</p>
            <div class="press-item-foot">
              <span class="press-region-tag">${escHtml(i.region)}</span>
              <span class="press-read">Read at ${escHtml(i.source)} <span aria-hidden="true">→</span></span>
            </div>
          </a>
        </li>`;
    }

    // Wire controls
    let debounce;
    searchInput.addEventListener("input", () => {
      clearTimeout(debounce);
      debounce = setTimeout(() => {
        state.q = searchInput.value;
        renderList();
      }, 180);
    });
    clearBtn.addEventListener("click", () => {
      searchInput.value = "";
      state.q = "";
      renderList();
    });
    sortSelect.addEventListener("change", () => {
      state.sort = sortSelect.value;
      renderList();
    });

    // Init
    renderRegions();
    renderList();
  </script>

  <style>
    .press-inline-link {
      color: var(--color-red);
      border-bottom: 1.5px solid var(--color-red);
      text-decoration: none;
      font-weight: 700;
    }
    .press-inline-link:hover {
      background: var(--color-red);
      color: var(--color-on-dark);
    }
    .press-live {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px 10px 14px;
      border: 1px solid var(--color-rule);
      border-radius: 999px;
      background: var(--color-paper-2);
      font-size: 14px;
      color: var(--color-text);
    }
    .press-live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--color-red);
      box-shadow: 0 0 0 0 rgba(226, 42, 44, 0.6);
      animation: press-pulse 2s ease-out infinite;
    }
    @keyframes press-pulse {
      0% { box-shadow: 0 0 0 0 rgba(226, 42, 44, 0.6); }
      70% { box-shadow: 0 0 0 10px rgba(226, 42, 44, 0); }
      100% { box-shadow: 0 0 0 0 rgba(226, 42, 44, 0); }
    }

    .press-hero-photo {
      margin: 0;
      padding: 10px 10px 0;
      background: var(--color-on-dark);
      transform: rotate(1.4deg);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    }

    .press-kit-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      color: var(--color-on-dark);
      text-decoration: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      font-size: 15px;
      font-weight: 600;
      transition: color 0.15s, padding 0.15s;
    }
    .press-kit-card-list:last-child .press-kit-link,
    .press-kit-link:last-child { border-bottom: none; }
    .press-kit-link:hover {
      color: var(--color-mustard);
      padding-left: 4px;
    }
    .press-kit-mail {
      color: var(--color-on-dark);
      font-size: 18px;
      font-weight: 700;
      text-decoration: none;
      border-bottom: 1.5px solid rgba(255, 255, 255, 0.3);
    }
    .press-kit-mail:hover {
      color: var(--color-mustard);
      border-bottom-color: var(--color-mustard);
    }

    /* Controls */
    .press-search {
      flex: 1;
      min-width: 280px;
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 0 16px;
      height: 48px;
      background: var(--color-card);
      border: 1px solid var(--color-rule);
      border-radius: 10px;
    }
    .press-search input {
      flex: 1;
      border: 0;
      outline: 0;
      background: transparent;
      font: 500 16px/1 var(--font-body);
      color: var(--color-text);
    }
    .press-search input::placeholder { color: var(--color-muted); }
    .press-sort {
      display: flex;
      align-items: center;
      gap: 10px;
      height: 48px;
      padding: 0 14px 0 16px;
      background: var(--color-card);
      border: 1px solid var(--color-rule);
      border-radius: 10px;
    }

    .press-region {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 14px;
      border-radius: 999px;
      background: var(--color-card);
      border: 1px solid var(--color-rule);
      font: 700 13px/1 var(--font-body);
      color: var(--color-text);
      cursor: pointer;
      transition: background 0.15s, color 0.15s, border-color 0.15s;
    }
    .press-region span {
      font-size: 11px;
      font-weight: 700;
      color: var(--color-muted);
      padding: 2px 7px;
      border-radius: 999px;
      background: var(--color-paper-2);
    }
    .press-region:hover {
      border-color: var(--color-ink-lilac);
      color: var(--color-ink);
    }
    .press-region.is-active {
      background: var(--color-ink);
      color: var(--color-on-dark);
      border-color: var(--color-ink);
    }
    .press-region.is-active span {
      background: rgba(255, 255, 255, 0.14);
      color: var(--color-on-dark);
    }

    /* List */
    .press-group-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding-bottom: 14px;
      margin-top: 48px;
      margin-bottom: 4px;
      border-bottom: 2px solid var(--color-ink);
    }
    .press-group-head:first-child { margin-top: 0; }
    .press-group-title {
      font-family: var(--font-display);
      font-size: 34px;
      font-weight: 400;
      color: var(--color-ink);
      margin: 0;
      letter-spacing: -0.005em;
    }
    .press-group-count {
      font: 800 12px/1 var(--font-body);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
    .press-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .press-item { border-bottom: 1px solid var(--color-rule); }
    .press-item-link {
      display: block;
      padding: 24px 0 28px;
      text-decoration: none;
      color: inherit;
      transition: padding 0.15s ease;
    }
    .press-item-link:hover { padding-left: 14px; }
    .press-item-link:hover .press-item-title { color: var(--color-red); }
    .press-item-link:hover .press-read { color: var(--color-red); }
    .press-item-link:focus-visible {
      outline: 2px solid var(--color-red);
      outline-offset: 4px;
    }
    .press-item-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      font: 700 13px/1 var(--font-body);
      color: var(--color-muted);
      margin-bottom: 10px;
    }
    .press-source {
      color: var(--color-ink-soft);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 12px;
    }
    .press-dot-sep { color: var(--color-rule); }
    .press-gaggle {
      color: var(--color-text-soft);
      font-style: italic;
      font-weight: 500;
    }
    .press-item-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 34px;
      line-height: 1.1;
      color: var(--color-ink);
      margin: 0 0 12px;
      letter-spacing: -0.005em;
      max-width: 32ch;
      transition: color 0.15s ease;
    }
