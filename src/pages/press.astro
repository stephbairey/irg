---
import BaseLayout from "../layouts/BaseLayout.astro";
import { readFileSync, existsSync } from "node:fs";
import { resolve } from "node:path";

interface Clipping {
  title: string;
  source: string;
  url: string;
  published_at: string;
  snippet: string;
  image_url: string | null;
  fetched_at: string;
}

const ARCHIVE = resolve(process.cwd(), "data/press-clippings.json");
let items: Clipping[] = [];
if (existsSync(ARCHIVE)) {
  try {
    const raw = JSON.parse(readFileSync(ARCHIVE, "utf8"));
    if (Array.isArray(raw)) items = raw as Clipping[];
  } catch {
    items = [];
  }
}

// Defensive sort: archive should already be newest-first, but don't trust it.
items.sort((a, b) => (b.published_at || "").localeCompare(a.published_at || ""));

const dateFmt = new Intl.DateTimeFormat("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});
function formatDate(iso: string) {
  if (!iso) return "";
  const d = new Date(iso + "T00:00:00");
  return Number.isNaN(d.getTime()) ? iso : dateFmt.format(d);
}
function yearOf(iso: string) {
  return iso?.slice(0, 4) || "Undated";
}

// Group by year only when the archive spans multiple years.
const yearsSet = new Set(items.map((i) => yearOf(i.published_at)));
const groupByYear = yearsSet.size > 1;
const groups: { year: string; items: Clipping[] }[] = [];
if (groupByYear) {
  let current: { year: string; items: Clipping[] } | null = null;
  for (const item of items) {
    const y = yearOf(item.published_at);
    if (!current || current.year !== y) {
      current = { year: y, items: [] };
      groups.push(current);
    }
    current.items.push(item);
  }
} else if (items.length) {
  groups.push({ year: "", items });
}

const latest = items[0];
const totalCount = items.length;
let liveLabel = "";
if (latest) {
  const days = Math.floor(
    (Date.now() - new Date(latest.published_at + "T00:00:00").getTime()) / 86_400_000,
  );
  liveLabel =
    days < 0
      ? "today"
      : days === 0
        ? "today"
        : days === 1
          ? "yesterday"
          : days < 30
            ? `${days} days ago`
            : days < 365
              ? `${Math.floor(days / 30)} month${Math.floor(days / 30) === 1 ? "" : "s"} ago`
              : `${Math.floor(days / 365)} year${Math.floor(days / 365) === 1 ? "" : "s"} ago`;
}
---

<BaseLayout title="In the News">
  <article class="press-page">
    {/* Hero */}
    <section class="bg-paper border-b-[3px] border-double border-ink">
      <div class="max-w-[1240px] mx-auto px-10 pt-12 pb-12">
        <div class="flex justify-between gap-6 flex-wrap text-muted font-bold text-xs tracking-[.12em] uppercase border-b border-rule pb-3.5 mb-9">
          <span>The Clippings Desk</span>
          <span>Auto-fetched · The News API</span>
          <span>{totalCount} {totalCount === 1 ? "story" : "stories"} on file</span>
        </div>

        <div class="grid grid-cols-[1.8fr_1fr] gap-14 items-start">
          {/* Left: title + dek + live feed */}
          <div>
            <div class="kicker text-red mb-4">Press &amp; Coverage</div>
            <h1 class="font-display text-ink leading-[.92] tracking-tight" style="font-size:clamp(64px,9vw,128px)">
              In the News
            </h1>
            <p class="text-[20px] leading-[1.5] text-text mt-5 max-w-[56ch]">
              What they're saying about us. Every mention of <em class="text-ink not-italic font-semibold italic">Raging Grannies</em> the alert bot can find — clipped automatically and stacked newest first. If something's missing, the bot probably missed it; <a href="mailto:press@raginggrannies.org?subject=Press%20mention" class="press-inline-link">send it our way</a>.
            </p>

            {latest && (
              <div class="press-live mt-7">
                <span class="press-live-dot" aria-hidden="true"></span>
                <span>
                  <b class="text-ink font-extrabold">Live feed.</b>
                  Latest clipping added {liveLabel} — <em class="text-ink-soft italic font-semibold">{latest.source}</em>.
                </span>
              </div>
            )}
          </div>

          {/* Right: photo + press kit */}
          <aside>
            <figure class="press-hero-photo">
              <img src="/granny-movement.jpg" alt="A Raging Grannies gaggle posed in front of a state capitol" class="w-full h-[220px] object-cover" style="filter:saturate(.9) contrast(1.02)" />
              <figcaption class="font-bold text-[11px] tracking-[.08em] uppercase text-ink text-center py-3 px-1">
                The Madison gaggle, post-rally · 2025
              </figcaption>
            </figure>

            <div class="bg-ink text-on-dark p-7 pt-7 pb-6 rounded-[10px] mt-5">
              <div class="kicker text-mustard mb-2">For Journalists</div>
              <div class="font-display text-on-dark text-[40px] leading-none mb-5">Press Kit</div>
              <ul class="list-none p-0 m-0 grid gap-0.5 mb-5">
                <li><a href="#" class="press-kit-link">Photography (CC-BY) <span aria-hidden="true">→</span></a></li>
                <li><a href="#" class="press-kit-link">Fact sheet &amp; timeline <span aria-hidden="true">→</span></a></li>
                <li><a href="#" class="press-kit-link">Spokesperson directory <span aria-hidden="true">→</span></a></li>
              </ul>
              <div class="pt-4 border-t border-white/15">
                <div class="font-bold text-[11px] tracking-[.14em] uppercase text-ink-lilac mb-1.5">Media inquiries</div>
                <a href="mailto:press@raginggrannies.org" class="press-kit-mail">press@raginggrannies.org</a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    {/* Clippings list */}
    <section class="bg-paper">
      <div class="max-w-[1240px] mx-auto px-10 pt-12 pb-16">
        {items.length === 0 ? (
          <div class="text-center py-16 px-10 bg-paper-2 border border-dashed border-rule rounded-[10px] grid gap-2 max-w-[640px] mx-auto">
            <b class="font-display text-ink text-[28px] font-normal">No clippings yet.</b>
            <span class="text-[15px] text-text-soft">The alert bot hasn't found anything matching <em>"Raging Grannies"</em> yet. Check back soon.</span>
          </div>
        ) : (
          groups.map((group) => (
            <div class="press-group">
              {group.year && (
                <div class="press-group-head">
                  <h3 class="press-group-title">{group.year}</h3>
                  <span class="press-group-count">{group.items.length} {group.items.length === 1 ? "story" : "stories"}</span>
                </div>
              )}
              <ol class="press-list">
                {group.items.map((item) => (
                  <li class="press-item">
                    <a href={item.url} target="_blank" rel="noopener" class="press-item-link">
                      <div class="press-item-row">
                        <div class="press-item-text">
                          <div class="press-item-meta">
                            <span class="press-source">{item.source}</span>
                            <span class="press-dot-sep" aria-hidden="true">·</span>
                            <time datetime={item.published_at}>{formatDate(item.published_at)}</time>
                          </div>
                          <h4 class="press-item-title">{item.title}</h4>
                          {item.snippet && <p class="press-item-snippet">{item.snippet}</p>}
                          <div class="press-item-foot">
                            <span class="press-read">Read at {item.source} <span aria-hidden="true">→</span></span>
                          </div>
                        </div>
                        {item.image_url && (
                          <div class="press-item-thumb">
                            <img
                              src={item.image_url}
                              alt=""
                              loading="lazy"
                              referrerpolicy="no-referrer"
                              onerror="this.parentElement.style.display='none'"
                            />
                          </div>
                        )}
                      </div>
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          ))
        )}

        <div class="press-foot-note mt-14">
          <div>
            <b class="text-ink font-extrabold">How this page works.</b>
            A daily query against <em class="text-ink italic">The News API</em> for "Raging Grannies" pulls fresh coverage into <code class="px-1.5 py-0.5 bg-paper rounded text-[12px] text-ink-soft">data/press-clippings.json</code> at build time. New entries are deduped by title and merged with what's already on file. No editors, no curated narrative. Just what the press is saying.
          </div>
          <a href="/rss.xml" class="press-foot-rss">
            Subscribe to the feed <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  </article>

  <style>
    .press-inline-link {
      color: var(--color-red);
      border-bottom: 1.5px solid var(--color-red);
      text-decoration: none;
      font-weight: 700;
    }
    .press-inline-link:hover {
      background: var(--color-red);
      color: var(--color-on-dark);
    }
    .press-live {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding: 10px 16px 10px 14px;
      border: 1px solid var(--color-rule);
      border-radius: 999px;
      background: var(--color-paper-2);
      font-size: 14px;
      color: var(--color-text);
    }
    .press-live-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--color-red);
      box-shadow: 0 0 0 0 rgba(226, 42, 44, 0.6);
      animation: press-pulse 2s ease-out infinite;
    }
    @keyframes press-pulse {
      0% { box-shadow: 0 0 0 0 rgba(226, 42, 44, 0.6); }
      70% { box-shadow: 0 0 0 10px rgba(226, 42, 44, 0); }
      100% { box-shadow: 0 0 0 0 rgba(226, 42, 44, 0); }
    }

    .press-hero-photo {
      margin: 0;
      padding: 10px 10px 0;
      background: var(--color-on-dark);
      transform: rotate(1.4deg);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.18);
    }

    .press-kit-link {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 0;
      color: var(--color-on-dark);
      text-decoration: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
      font-size: 15px;
      font-weight: 600;
      transition: color 0.15s, padding 0.15s;
    }
    .press-kit-link:hover {
      color: var(--color-mustard);
      padding-left: 4px;
    }
    .press-kit-mail {
      color: var(--color-on-dark);
      font-size: 18px;
      font-weight: 700;
      text-decoration: none;
      border-bottom: 1.5px solid rgba(255, 255, 255, 0.3);
    }
    .press-kit-mail:hover {
      color: var(--color-mustard);
      border-bottom-color: var(--color-mustard);
    }

    .press-group + .press-group { margin-top: 56px; }
    .press-group-head {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding-bottom: 14px;
      margin-bottom: 4px;
      border-bottom: 2px solid var(--color-ink);
    }
    .press-group-title {
      font-family: var(--font-display);
      font-size: 44px;
      font-weight: 400;
      color: var(--color-ink);
      margin: 0;
      letter-spacing: -0.005em;
      line-height: 1;
    }
    .press-group-count {
      font: 800 12px/1 var(--font-body);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--color-muted);
    }
    .press-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .press-item { border-bottom: 1px solid var(--color-rule); }
    .press-item-link {
      display: block;
      padding: 24px 0 28px;
      text-decoration: none;
      color: inherit;
      transition: padding 0.15s ease;
    }
    .press-item-link:hover { padding-left: 14px; }
    .press-item-link:hover .press-item-title { color: var(--color-red); }
    .press-item-link:hover .press-read { color: var(--color-red); }
    .press-item-link:focus-visible {
      outline: 2px solid var(--color-red);
      outline-offset: 4px;
    }
    .press-item-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: start;
    }
    .press-item-text { min-width: 0; }
    .press-item-thumb {
      width: 140px;
      height: 100px;
      overflow: hidden;
      border-radius: 6px;
      background: var(--color-paper-2);
      flex-shrink: 0;
    }
    .press-item-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .press-item-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px;
      font: 700 13px/1 var(--font-body);
      color: var(--color-muted);
      margin-bottom: 10px;
    }
    .press-source {
      color: var(--color-ink-soft);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 12px;
    }
    .press-dot-sep { color: var(--color-rule); }
    .press-item-title {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: 32px;
      line-height: 1.15;
      color: var(--color-ink);
      margin: 0 0 12px;
      letter-spacing: -0.005em;
      max-width: 32ch;
      transition: color 0.15s ease;
    }
    .press-item-snippet {
      margin: 0;
      font-size: 17px;
      line-height: 1.55;
      color: var(--color-text);
      max-width: 72ch;
    }
    .press-item-foot {
      margin-top: 14px;
    }
    .press-read {
      font: 700 13px/1 var(--font-body);
      color: var(--color-text-soft);
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: color 0.15s ease;
    }

    .press-foot-note {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: center;
      padding: 28px 32px;
      background: var(--color-paper-2);
      border-left: 3px solid var(--color-ink-soft);
      border-radius: 0 10px 10px 0;
      font-size: 14px;
      line-height: 1.55;
      color: var(--color-text-soft);
    }
    .press-foot-rss {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 999px;
      background: var(--color-ink);
      color: var(--color-on-dark);
      font: 700 13px/1 var(--font-body);
      text-decoration: none;
      white-space: nowrap;
    }
    .press-foot-rss:hover { background: var(--color-red); }

    @media (max-width: 720px) {
      .press-item-row { grid-template-columns: 1fr; }
      .press-item-thumb { width: 100%; height: 180px; }
    }
  </style>
</BaseLayout>
