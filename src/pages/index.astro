---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchAllSongs } from "../lib/songs";
import { fetchLatestActions } from "../lib/actions";
import { getActiveGaggleCount } from "../lib/gaggles";

const activeGaggleCount = getActiveGaggleCount();

const [allSongs, latestActions] = await Promise.all([
  fetchAllSongs(),
  fetchLatestActions(7),
]);

const dateFmt = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
function formatActionDate(iso: string): string {
  const d = new Date(iso);
  return Number.isNaN(d.getTime()) ? "" : dateFmt.format(d);
}
function truncateExcerpt(html: string, maxLen = 140): string {
  const stripped = html
    .replace(/<[^>]+>/g, "")
    .replace(/&nbsp;/gi, " ")
    .replace(/&#8217;|&rsquo;/gi, "'")
    .replace(/&#8220;|&#8221;|&ldquo;|&rdquo;/gi, '"')
    .replace(/&amp;/gi, "&")
    .replace(/&hellip;/gi, "…")
    .replace(/&[a-z#0-9]+;/gi, "")
    .replace(/\s+/g, " ")
    .trim();
  if (stripped.length <= maxLen) return stripped;
  return stripped.slice(0, maxLen).replace(/\s\S*$/, "") + "…";
}

// Derive issues from the song corpus instead of a separate WPGraphQL call.
// Keeps the homepage build self-contained against the committed JSON
// snapshot — won't break when the live WP endpoint is bot-blocked.
const issueCounts = new Map<string, number>();
for (const song of allSongs) {
  for (const issue of song.issues.nodes) {
    issueCounts.set(issue.name, (issueCounts.get(issue.name) ?? 0) + 1);
  }
}
const issues = Array.from(issueCounts, ([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
const totalSongs = allSongs.length;

function stripHtml(html: string): string {
  return html
    .replace(/&amp;/gi, "&")
    .replace(/&nbsp;/gi, " ")
    .replace(/&#8217;|&#8216;|&rsquo;|&lsquo;/gi, "'")
    .replace(/&#8220;|&#8221;|&ldquo;|&rdquo;/gi, '"')
    .replace(/&quot;/gi, '"')
    .replace(/&#0?39;/gi, "'")
    .replace(/&lt;/gi, "<")
    .replace(/&gt;/gi, ">")
    .replace(/<br\s*\/?>/gi, "\n")
    .replace(/<\/p>/gi, "\n")
    .replace(/<[^>]+>/g, "")
    .replace(/\b\/?(?:em|strong|p|br|b|i|u|span)>/gi, "")
    .replace(/&[a-z#0-9]+;/gi, "")
    .trim();
}

// Pick a random featured song whose lyrics fall within a target word count.
// Build-time only; runs once per build. If the primary range yields nothing,
// widen by 10 words on each side and try again.
function wordCount(html: string): number {
  return stripHtml(html).split(/\s+/).filter(Boolean).length;
}
function pickFeatured(min: number, max: number) {
  const eligible = allSongs.filter((s) => {
    const lyrics = s.songDetails?.lyrics;
    if (!lyrics) return false;
    const wc = wordCount(lyrics);
    return wc >= min && wc <= max;
  });
  if (eligible.length === 0) return null;
  return eligible[Math.floor(Math.random() * eligible.length)];
}
const featured = pickFeatured(175, 195) ?? pickFeatured(165, 205);

const gaggleNames = new Set<string>();
for (const s of allSongs) for (const g of s.gaggles.nodes) gaggleNames.add(g.name);
const gagglesCount = gaggleNames.size;

const yearsSinging = new Date().getFullYear() - 1987;

const featuredLyrics = featured?.songDetails?.lyrics
  ? stripHtml(featured.songDetails.lyrics)
      .split("\n")
      .map((l) => l.trim())
      .filter(Boolean)
      .slice(0, 32)
      .join("\n")
  : "";
---

<BaseLayout title="Home">
  <!-- Masthead -->
  <section class="bg-paper pt-12 pb-8 border-b border-muted">
    <div class="max-w-[1400px] mx-auto px-8">
      <div class="flex justify-between text-muted font-bold text-xs tracking-[.1em] uppercase border-b border-rule pb-3 mb-5">
        <span>Welcome, friend</span>
        <span>The International Disorganization</span>
        <span>Est. Victoria, BC · 1987</span>
      </div>
      <h1 class="font-display text-center text-ink leading-[.9] tracking-tight" style="font-size:clamp(72px,11vw,160px)">
        Raging Grannies
      </h1>
      <p class="text-center text-[19px] text-text-soft mt-10 italic">
        Using <em class="text-ink">creative and humorous</em> protests for political education.
      </p>
    </div>
  </section>

  <!-- Front Page Grid -->
  <section class="max-w-[1400px] mx-auto px-8">
    <div class="grid grid-cols-[3fr_4fr_3fr] border-l border-rule">
      <!-- Lead story -->
      <div class="p-7 border-r border-b border-muted">
        <div class="kicker text-red mb-3.5">From the Songbook</div>
        {featured && (
          <>
            <h2 class="font-display text-ink text-[56px] leading-[.98] mb-2.5">
              <a href={`/songs/${featured.slug}/`} class="text-ink no-underline hover:text-red transition-colors">{featured.title}</a>
            </h2>
            <p class="text-sm text-text-soft pb-4 border-b border-rule mb-5">
              By <strong class="text-ink">{featured.songwriters.nodes[0]?.name}</strong>
              {featured.gaggles.nodes[0] && <> · {featured.gaggles.nodes[0].name} Gaggle</>}
              {featured.tunes.nodes[0] && <> · to the tune of <em class="text-ink-soft">{featured.tunes.nodes[0].name}</em></>}
            </p>
            <div class="text-[17px] leading-relaxed text-text whitespace-pre-line mb-4">{featuredLyrics}</div>
            <a href={`/songs/${featured.slug}/`} class="inline-flex items-center gap-1.5 font-[800] text-red no-underline hover:underline">
              Read full lyrics →
            </a>
          </>
        )}
      </div>

      <!-- Who we are + From the archive -->
      <div class="border-r border-b border-muted">
        <div class="p-7 bg-paper-2">
          <div class="kicker text-red mb-3.5">Who we are</div>
          <p class="text-[17px] leading-normal mb-3.5">
            <strong class="text-ink">The Raging Grannies</strong> are a loose international network of women over fifty who use satirical song and street theater as a tool for political education.
          </p>
          <p class="text-[17px] leading-normal mb-3.5">
            Our autonomous gaggles across North America don flowered hats and show up to sing pointed songs about what the powerful would rather keep quiet. We care about peace and justice and human rights and this battered planet, and use a well-aimed song on the steps of city hall to open ears.
          </p>

          <div class="mt-7 pt-7 border-t border-dashed border-muted">
            <div class="kicker text-red mb-3.5">By the numbers</div>
            <dl>
              <div class="flex justify-between py-2 border-b border-dotted border-muted">
                <dt class="text-[15px] text-text-soft">Active gaggles</dt>
                <dd class="font-display text-ink text-[26px] leading-none">{gagglesCount}</dd>
              </div>
              <div class="flex justify-between py-2 border-b border-dotted border-muted">
                <dt class="text-[15px] text-text-soft">Songs archived</dt>
                <dd class="font-display text-ink text-[26px] leading-none">{totalSongs.toLocaleString()}</dd>
              </div>
              <div class="flex justify-between py-2 border-b border-dotted border-muted">
                <dt class="text-[15px] text-text-soft">Issue categories</dt>
                <dd class="font-display text-ink text-[26px] leading-none">{issues.length}</dd>
              </div>
              <div class="flex justify-between py-2">
                <dt class="text-[15px] text-text-soft">Years singing</dt>
                <dd class="font-display text-ink text-[26px] leading-none">{yearsSinging}</dd>
              </div>
            </dl>
          </div>
        </div>

        <div class="p-7 bg-ink text-on-dark">
          <div class="kicker text-mustard mb-3.5">From the archive</div>
          <h2 class="font-display text-on-dark text-[28px] leading-tight mb-4 m-0">The Origin Story</h2>
          <figure class="my-3.5 p-2 pb-0 bg-on-dark inline-block" style="transform:rotate(-1.2deg);box-shadow:0 8px 20px rgba(0,0,0,.25);max-width:420px">
            <img src="/granny-origin.png" alt="The Raging Grannies" class="w-full h-[180px] object-cover" style="filter:saturate(.85) contrast(1.02)" />
            <figcaption class="font-bold text-[11px] tracking-[.08em] uppercase text-ink text-center py-2.5 px-1 italic">The Raging Grannies</figcaption>
          </figure>
          <div class="font-display text-red text-[120px] leading-none my-2.5">1987</div>
          <p class="text-[17px] leading-relaxed text-on-dark max-w-[540px] mb-4">
            It started on a <em class="text-mustard not-italic">damp Tuesday in Victoria, BC</em> when a handful of older women decided the best way to get attention for peace was to put on flowered hats and sing.
          </p>
          <a href="/herstory/" class="inline-flex items-center gap-1.5 font-[800] text-mustard text-sm no-underline hover:underline">
            Read the full herstory →
          </a>
        </div>
      </div>

      <!-- On The Streets -->
      <div class="p-7 border-r border-b border-muted">
        <div class="kicker text-red mb-3.5">On the streets</div>
        <h2 class="font-display text-ink text-[28px] leading-tight mb-4 m-0">Dispatches</h2>
        {latestActions.length === 0 ? (
          <p class="text-sm text-text-soft italic">Gaggle action reports coming soon.</p>
        ) : (
          <ul class="list-none p-0 m-0 grid gap-5">
            {latestActions.map((a) => (
              <li class="pb-4 border-b border-dotted border-muted last:border-b-0 last:pb-0">
                <div class="kicker text-muted mb-1.5">{a.gaggle} · {formatActionDate(a.date)}</div>
                <a href={a.link} class="block font-display text-ink text-[20px] leading-tight no-underline hover:text-red transition-colors mb-2">
                  {a.title}
                </a>
                <p class="text-[14px] text-text-soft leading-snug">{truncateExcerpt(a.excerpt)}</p>
              </li>
            ))}
          </ul>
        )}
      </div>

    </div>
  </section>

  <!-- Issues Grid -->
  <section class="py-20 bg-paper-2">
    <div class="max-w-[1200px] mx-auto px-8">
      <div class="text-center mb-10">
        <div class="kicker text-red mb-3">The songbook · by issue</div>
        <h2 class="font-display text-ink text-[44px] leading-none">What We Sing About</h2>
      </div>
      <div class="grid grid-cols-3 border-t border-l border-muted">
        {issues.map((issue) => (
          <a
            href={`/songs/?issue=${encodeURIComponent(issue.name)}`}
            class="flex items-baseline justify-between gap-4 px-6 py-[22px] border-r border-b border-muted bg-paper text-ink no-underline hover:bg-red hover:text-on-dark transition-colors group"
          >
            <span class="font-bold text-[16px] text-right">{issue.name}</span>
            <span class="font-display text-[40px] leading-none text-red group-hover:text-on-dark transition-colors">{issue.count}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Gaggle Map Teaser -->
  <section class="py-24">
    <div class="max-w-[1200px] mx-auto px-8 grid grid-cols-[1fr_1.4fr] gap-16 items-center">
      <div>
        <div class="kicker text-red mb-3">The network</div>
        <h2 class="font-display text-ink text-[56px] leading-[.98] mb-5">Find Your Gaggle</h2>
        <p class="text-[19px] text-text-soft leading-normal mb-8">
          {activeGaggleCount} gaggles across the US, Canada, and beyond. Find one near you, or start your own.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href="/find-a-gaggle/" class="btn btn-pill">Find a gaggle</a>
          <a href="/start-a-gaggle/" class="btn btn-pill">Start a gaggle</a>
        </div>
      </div>
      <a
        href="/find-a-gaggle/"
        class="block rounded-xl overflow-hidden border border-muted bg-paper-2 aspect-[16/10] hover:opacity-95 transition-opacity"
        aria-label="View the full map of gaggles"
      >
        <img
          src="/granny-map.jpg"
          alt="Map of Raging Grannies gaggles across North America"
          class="w-full h-full object-cover"
        />
      </a>
    </div>
  </section>

  <!-- About Strip -->
  <section class="py-[72px] bg-paper-2 border-t border-b border-rule">
    <div class="max-w-[1200px] mx-auto px-8 grid grid-cols-[0.9fr_1.1fr] gap-14 items-center">
      <figure class="p-3.5 pt-3.5 pb-0 bg-on-dark" style="transform:rotate(-1.5deg);box-shadow:0 14px 36px rgba(0,0,0,.18);border:1px solid rgba(0,0,0,.04)">
        <img src="/granny-movement.jpg" alt="Raging Grannies of Madison" class="w-full aspect-[4/3] object-cover" style="filter:saturate(.9) contrast(1.02)" />
        <figcaption class="font-bold text-xs tracking-[.04em] text-ink text-center py-3.5 px-1.5 italic">Raging Grannies of Madison</figcaption>
      </figure>
      <div>
        <div class="kicker text-red mb-3">About the movement</div>
        <h2 class="font-display text-ink text-[56px] leading-[1.05] mb-5 tracking-tight">
          Older women, flowered hats, <em class="text-red italic">sharp lyrics.</em>
        </h2>
        <p class="text-[18px] leading-relaxed text-text max-w-[52ch] mb-5">
          We are not a club, a party, or an organization. We are a loose network of autonomous gaggles united by a shared method: writing satirical songs about the issues that matter and singing them in public.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href="/herstory/" class="btn btn-pill-ink">Our herstory</a>
          <a href="/philosophy/" class="btn btn-pill-ink">Our philosophy</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Teaser -->
  <section class="py-24">
    <div class="max-w-[1200px] mx-auto px-8 grid grid-cols-[340px_1fr] gap-16 items-start">
      <div class="sticky top-6">
        <figure class="mb-6 p-2.5 pt-2.5 pb-0 bg-on-dark inline-block max-w-[300px]" style="transform:rotate(1.5deg);box-shadow:0 10px 28px rgba(0,0,0,.18)">
          <img src="/granny-faq.jpg" alt="" class="w-full h-[220px] object-cover" style="filter:saturate(.9)" />
          <figcaption class="font-bold text-[11px] tracking-[.08em] uppercase text-ink text-center py-2.5 px-1 italic">&nbsp;</figcaption>
        </figure>
        <h2 class="font-display text-ink text-[52px] leading-[.95] mt-2.5 mb-3.5">FAQ</h2>
        <p class="text-[16px] text-text-soft leading-relaxed max-w-[32ch] mb-4">
          The questions we get most, and a few you haven't thought of yet.
        </p>
      </div>
      <div>
        <details open class="border-b border-rule py-5 group">
          <summary class="flex justify-between items-center cursor-pointer list-none font-display text-ink text-[22px] leading-tight">
            <span>Do I have to be a grandmother to join?</span>
            <span class="text-muted text-xl transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-4 text-text-soft leading-relaxed text-[17px]" style="max-width:75ch">
            Nope. "Granny" is a state of mind. You don't need grandchildren, and you don't even need children. You just need to care about the world they're inheriting.
          </p>
        </details>
        <details class="border-b border-rule py-5 group">
          <summary class="flex justify-between items-center cursor-pointer list-none font-display text-ink text-[22px] leading-tight">
            <span>What issues do the Raging Grannies sing about?</span>
            <span class="text-muted text-xl transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-4 text-text-soft leading-relaxed text-[17px]" style="max-width:75ch">
            Whatever needs raging about. Peace and anti-militarism (the founding issue), the environment and climate, healthcare, reproductive rights, racism, economic inequality, ageism, and whatever else needs naming this week. Each gaggle picks its own focus based on what's happening locally.
          </p>
        </details>
        <details class="border-b border-rule py-5 group">
          <summary class="flex justify-between items-center cursor-pointer list-none font-display text-ink text-[22px] leading-tight">
            <span>How do I find a gaggle near me?</span>
            <span class="text-muted text-xl transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-4 text-text-soft leading-relaxed text-[17px] faq-prose" style="max-width:75ch">
            Check the map on our <a href="/find-a-gaggle/">Find a Gaggle</a> page. If there isn't one nearby, keep reading. The next question is for you.
          </p>
        </details>
        <details class="border-b border-rule py-5 group">
          <summary class="flex justify-between items-center cursor-pointer list-none font-display text-ink text-[22px] leading-tight">
            <span>Are the Raging Grannies affiliated with a political party?</span>
            <span class="text-muted text-xl transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-4 text-text-soft leading-relaxed text-[17px]" style="max-width:75ch">
            No. We are not a political party and we are not affiliated with one. Individual grannies hold all kinds of political views. What unites us is a commitment to peace, justice, and the belief that ordinary women can make extraordinary noise. We take positions on issues, not personalities.
          </p>
        </details>
        <details class="border-b border-rule py-5 group">
          <summary class="flex justify-between items-center cursor-pointer list-none font-display text-ink text-[22px] leading-tight">
            <span>Why are the Grannies "Raging"?</span>
            <span class="text-muted text-xl transition-transform group-open:rotate-180">▾</span>
          </summary>
          <p class="mt-4 text-text-soft leading-relaxed text-[17px]" style="max-width:75ch">
            The "raging" in our name refers to creative rage: a combination of deep compassion, concern for the future, and a willingness to confront social issues with wit and perseverance. We rage because we care. And we do it with song, humor, and a flowered hat, because nothing catches people off guard quite like strong lyrics coming from sweet little old ladies.
          </p>
        </details>
        <p class="mt-8 text-[15px] text-text-soft">
          More questions? <a href="/faq/" class="font-[800] text-red no-underline hover:underline">See our full FAQ →</a>
        </p>
      </div>
    </div>
  </section>

  <style>
    .faq-prose :global(a) {
      color: var(--color-red);
      text-decoration: none;
      border-bottom: 1.5px solid var(--color-red);
      font-weight: 600;
      transition: background 0.15s ease, color 0.15s ease;
    }
    .faq-prose :global(a:hover) {
      background: var(--color-red);
      color: var(--color-on-dark);
    }
  </style>
</BaseLayout>
