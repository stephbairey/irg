PUBLIC_WP_URL=https://cms.raginggrannies.international
PUBLIC_WP_GRAPHQL_ENDPOINT=https://cms.raginggrannies.international/graphql

# Multisite subsites: comma-separated `slug:Display Name` pairs.
# Each subsite's GraphQL endpoint is derived as {PUBLIC_WP_URL}/{slug}/graphql.
# Add entries as new gaggles come online. Slug must match the WP subsite path.
PUBLIC_WP_SUBSITES=portland:Portland,seattle:Seattle

# WP REST credentials for migration/deploy scripts (never commit; gitignored in .env.local).
WP_USERNAME=
WP_APP_PASSWORD=
