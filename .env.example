PUBLIC_WP_URL=https://cms.raginggrannies.international
PUBLIC_WP_GRAPHQL_ENDPOINT=https://cms.raginggrannies.international/graphql

# Subsite list is discovered at build time from irg-core's REST endpoint:
#   GET {PUBLIC_WP_URL}/wp-json/irg/v1/subsites
# Add a new gaggle in WP Network Admin and it appears automatically — no
# code or config change required.

# WP REST credentials for migration/deploy scripts (never commit; gitignored in .env.local).
WP_USERNAME=
WP_APP_PASSWORD=

# The News API key — used by scripts/fetch-press.mjs at build time (D027).
# Free tier at https://www.thenewsapi.com. Optional — page renders from
# the existing data/press-clippings.json archive if the key is missing.
THENEWSAPI_KEY=
